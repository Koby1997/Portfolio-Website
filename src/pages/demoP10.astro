---
import '../styles/global.css';

// The Neural Network configuration mapping
const hubs = [
    {
        name: 'KINETICS',
        x: '15vw', y: '15vh', z: -1500,
        color: 'bg-orange-500 shadow-[0_0_150px_rgba(249,115,22,0.6)]',
        textColor: 'text-orange-400',
        children: ['Volleyball', 'Lacrosse', 'Rock Climbing', 'Paintball', 'Dodgeball', 'Traveling']
    },
    {
        name: 'ANALOG_TACTICS',
        x: '-25vw', y: '-20vh', z: -4000,
        color: 'bg-purple-500 shadow-[0_0_150px_rgba(168,85,247,0.6)]',
        textColor: 'text-purple-400',
        children: ['Magic the Gathering', 'Poker', 'Jigsaw Puzzles', 'Board Games', 'Escape Rooms']
    },
    {
        name: 'DIGITAL_NARRATIVE',
        x: '35vw', y: '-10vh', z: -7000,
        color: 'bg-emerald-500 shadow-[0_0_150px_rgba(16,185,129,0.6)]',
        textColor: 'text-emerald-400',
        children: ['Spider-Man', 'Ghost of Yōtei', 'God of War', 'The Last of Us']
    },
    {
        name: 'CINEMA',
        x: '-10vw', y: '30vh', z: -10000,
        color: 'bg-blue-500 shadow-[0_0_150px_rgba(59,130,246,0.6)]',
        textColor: 'text-blue-400',
        children: ['Tenet', 'Inception', 'Interstellar', 'Star Wars', 'Marvel']
    }
];

// Helper to generate a random seeded position for child nodes around the hub
function seededRandom(min, max) {
    return Math.random() * (max - min) + min;
}
---

<html lang="en" class="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>P.Brain Neural Engine</title>
    <style>
        .preserve-3d {
            transform-style: preserve-3d;
        }
        /* Hide scrollbars for cinematic effect but keep scroll functionality */
        ::-webkit-scrollbar {
            display: none;
        }
        .orb-pulse {
            animation: pulse-op 4s ease-in-out infinite alternate;
        }
        @keyframes pulse-op {
            0% { opacity: 0.6; transform: scale(0.9); }
            100% { opacity: 1; transform: scale(1.1); }
        }
    </style>
</head>
<body class="bg-black text-white m-0 p-0 font-sans h-[15000px] overflow-hidden select-none">
    
    <!-- User Interface Overlay (Fixed to screen) -->
    <div class="fixed top-8 left-8 z-50 pointer-events-auto">
        <a href="/" class="text-white font-mono tracking-[0.2em] text-xs hover:text-white/50 transition-colors uppercase pb-2 border-b border-white/20">
            &larr; Exit Neural Web
        </a>
    </div>
    
    <div class="fixed bottom-12 w-full text-center z-50 pointer-events-none">
        <p class="font-mono text-zinc-500 tracking-[0.4em] text-xs uppercase animate-pulse">Scroll to Zoom &bull; Drag to Pan</p>
    </div>

    <!-- The Master Camera Lens. It handles the 3D Perspective -->
    <div id="lens" class="fixed inset-0 w-full h-full cursor-grab active:cursor-grabbing perspective-[1000px] overflow-hidden z-10">
        
        <!-- The Camera Pan Container. Responsible for rotating the head X/Y -->
        <div id="camera-pan" class="absolute inset-0 w-full h-full preserve-3d will-change-transform transform-gpu">
            
            <!-- The Camera Zoom Container. Responsible for scrolling the head deep into Z -->
            <div id="camera-zoom" class="absolute top-1/2 left-1/2 w-0 h-0 preserve-3d will-change-transform transform-gpu">
                
                {hubs.map(hub => {
                    // The glowing Synapse Hubs
                    return (
                        <div class="preserve-3d absolute" style={`transform: translate3d(${hub.x}, ${hub.y}, ${hub.z}px);`}>
                            
                            <!-- Massive Organic Core Orb -->
                            <div class="absolute -translate-x-1/2 -translate-y-1/2 flex items-center justify-center">
                                <div class={`w-64 h-64 rounded-full blur-[80px] ${hub.color} orb-pulse`}></div>
                            </div>
                            
                            <!-- High Contrast Hub Title -->
                            <div class="absolute -translate-x-1/2 -translate-y-1/2 pointer-events-auto">
                                <h2 class="text-6xl font-black tracking-tighter text-white drop-shadow-[0_0_30px_rgba(255,255,255,1)] text-center whitespace-nowrap mix-blend-screen">{hub.name}</h2>
                            </div>

                            <!-- The Orbital Thoughts (Children Nodes) -->
                            {hub.children.map(child => {
                                // Spread children wildly around the neural hub
                                const offX = seededRandom(-800, 800);
                                const offY = seededRandom(-600, 600);
                                const offZ = seededRandom(-800, 800); // Massive 3D Z depth

                                return (
                                    <div class={`absolute preserve-3d group pointer-events-auto cursor-crosshair`} 
                                         style={`transform: translate3d(${offX}px, ${offY}px, ${offZ}px);`}>
                                        
                                        <!-- The physical Synapse Node floating in space -->
                                        <div class="relative flex items-center justify-center transition-transform duration-500 hover:scale-150">
                                            <!-- The glowing particle -->
                                            <div class="w-2 h-2 bg-white rounded-full shadow-[0_0_20px_white] z-10"></div>
                                            <!-- The trailing light bleed -->
                                            <div class={`absolute w-12 h-12 rounded-full blur-[20px] ${hub.color.split(' ')[0]} z-0`}></div>
                                            
                                            <!-- The specific thought title (Fades in slightly closer or visibly on hover) -->
                                            <span class={`absolute left-6 font-mono text-xs tracking-[0.2em] uppercase whitespace-nowrap opacity-60 group-hover:opacity-100 transition-opacity ${hub.textColor} drop-shadow-[0_0_10px_currentColor]`}>
                                                {child}
                                            </span>
                                        </div>

                                        <!-- The Translucent Web Connection Back to the Brain Core! -->
                                        <svg class="absolute top-0 left-0 overflow-visible pointer-events-none opacity-20 group-hover:opacity-60 transition-opacity duration-1000 mix-blend-screen">
                                            <line x1="0" y1="0" x2={-offX} y2={-offY} stroke="white" stroke-width="1" stroke-dasharray="4,4" />
                                        </svg>

                                    </div>
                                )
                            })}

                        </div>
                    )
                })}

            </div>
        </div>

        <!-- Deep Space Background Gradient Overlay -->
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_0%,#000_100%)] pointer-events-none z-0"></div>
    </div>

    <!-- The Javascript Engine handling Dual-Layer Space Math -->
    <script is:inline>
        const cameraPan = document.getElementById('camera-pan');
        const cameraZoom = document.getElementById('camera-zoom');
        const lens = document.getElementById('lens');

        // ----------------------------------------------------
        // LAYER 1: Z-AXIS SCROLL TRANSLATION (The Zoom)
        // ----------------------------------------------------
        function updateZSpace() {
            // How deep have we scrolled? Move the universe towards us
            const zDistance = window.scrollY;
            cameraZoom.style.transform = `translate3d(0, 0, ${zDistance}px)`;
        }

        window.addEventListener('scroll', () => {
            requestAnimationFrame(updateZSpace);
        });

        // Initialize Zoom on load
        requestAnimationFrame(updateZSpace);

        // ----------------------------------------------------
        // LAYER 2: X/Y-AXIS MOUSE TRANSLATION (The Look/Pan)
        // ----------------------------------------------------
        let rotX = 0;
        let rotY = 0;
        let isDragging = false;
        let startX = 0;
        let startY = 0;

        lens.addEventListener('pointerdown', (e) => {
            isDragging = true;
            startX = e.clientX;
            startY = e.clientY;
            lens.setPointerCapture(e.pointerId);
        });

        window.addEventListener('pointermove', (e) => {
            if (!isDragging) return;
            
            // Calculate mouse delta from where we clicked
            const dx = e.clientX - startX;
            const dy = e.clientY - startY;
            
            // Apply rotX and rotY mapped physics (friction applied via 0.15)
            rotY += dx * 0.15;
            // Negative dy because dragging up (y decreases) translates to looking up (positive rotateX usually tilts down though, so inverse mapping check needed)
            rotX -= dy * 0.15; 

            // Clamp max viewing angles so they don't break their neck entirely backwards
            if(rotX > 60) rotX = 60;
            if(rotX < -60) rotX = -60;

            // Apply orientation rotation to the Pan Container
            cameraPan.style.transform = `rotateX(${rotX}deg) rotateY(${rotY}deg)`;
            
            startX = e.clientX;
            startY = e.clientY;
        });

        window.addEventListener('pointerup', () => {
            isDragging = false;
        });
        
    </script>
</body>
</html>
