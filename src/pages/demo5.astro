---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Demo 5: The Master Timeline">
  <div class="max-w-5xl mx-auto py-8 px-4 relative z-10">
    <h1 class="text-3xl font-bold mb-4">Demo 5: The Grand Unified Timeline</h1>
    <p class="text-zinc-400 mb-2">Combines the Seamless Horizontal track, the Alternating Double-Side layout, and Horizontal Sticky Headers with more placeholder data to show scale.</p>
    <p class="text-emerald-400 text-sm font-mono">(Hover over the cards to see the 'Click to Expand' hooks!).</p>
  </div>
  
  <div class="w-screen relative left-[calc(-50vw+50%)] CustomScrollContainer overflow-x-auto pb-12 bg-zinc-950 h-[80vh] min-h-[660px] flex items-center">
    
    <!-- The Master Horizontal Line -->
    <div class="absolute top-1/2 left-0 w-[500%] h-1 bg-zinc-800 -translate-y-1/2 z-0 hidden md:block"></div>

    <div class="flex flex-col md:flex-row items-center px-12 min-w-max relative z-10 h-full mt-12 md:mt-0">

        <!-- YEAR 2023 SECTION -->
        <div class="flex flex-col md:flex-row relative h-full items-center mr-12 md:mr-32">
            <!-- The Sticky Year Header (Only Sticky On Desktop) -->
            <div class="md:sticky left-8 z-0 flex items-center self-stretch opacity-20 pointer-events-none mb-4 md:mb-0">
                <span class="text-[6rem] md:text-[12rem] font-black text-zinc-500 leading-none tracking-tighter mix-blend-overlay">2023</span>
            </div>

            <!-- Project 1: Top -->
            <div class="relative w-[90vw] md:w-96 flex flex-col items-center md:-mt-[24rem] group mx-0 md:mx-8 cursor-pointer mb-8 md:mb-0">
                <!-- Node & Trunk Line (Desktop Only) -->
                <div class="hidden md:block w-4 h-4 rounded-full bg-orange-500 absolute bottom-[-11.5rem] shadow-[0_0_15px_rgba(249,115,22,0.5)] z-20 transition-transform group-hover:scale-150"></div>
                <div class="hidden md:block absolute left-1/2 bottom-[-11rem] w-0.5 h-48 bg-zinc-800 z-10"></div>
                
                <!-- The Teaser Card -->
                <div class="w-full bg-zinc-900 border border-zinc-700 rounded-2xl overflow-hidden hover:border-orange-500 transition-all duration-300 md:group-hover:-translate-y-2 shadow-xl z-30 relative">
                    <div class="absolute top-4 right-4 w-8 h-8 bg-black/50 backdrop-blur rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                        <span class="text-white text-xs">⤢</span>
                    </div>
                    <div class="h-48 bg-zinc-800 flex items-center justify-center text-zinc-600">
                        <span>[ Photo: Cosplay Group ]</span>
                    </div>
                    <div class="p-6">
                        <span class="text-xs font-bold text-orange-500 tracking-widest uppercase mb-2 block">Events</span>
                        <h3 class="text-xl text-white font-bold mb-2">Ghetto Olympics V1</h3>
                        <p class="text-zinc-400 text-sm line-clamp-2">The inaugural games. Pure chaos, raw engineering, and incredibly cheap thrills.</p>
                    </div>
                </div>
            </div>

            <!-- Project 2: Bottom -->
            <div class="relative w-[90vw] md:w-96 flex flex-col items-center md:mt-[24rem] group mx-0 md:mx-8 cursor-pointer mb-8 md:mb-0">
                <div class="hidden md:block w-4 h-4 rounded-full bg-blue-500 absolute top-[-11.5rem] shadow-[0_0_15px_rgba(59,130,246,0.5)] z-20 group-hover:scale-150 transition-transform"></div>
                <div class="hidden md:block absolute left-1/2 top-[-11rem] w-0.5 h-48 bg-zinc-800 z-10"></div>
                
                <div class="w-full bg-zinc-900 border border-zinc-700 rounded-2xl overflow-hidden hover:border-blue-500 transition-all duration-300 md:group-hover:translate-y-2 shadow-xl z-30 relative">
                    <div class="absolute top-4 right-4 w-8 h-8 bg-black/50 backdrop-blur rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                        <span class="text-white text-xs">⤢</span>
                    </div>
                    <div class="h-48 bg-zinc-800 flex items-center justify-center text-zinc-600">
                        <span>[ Photo: Glowing Saber ]</span>
                    </div>
                    <div class="p-6">
                        <span class="text-xs font-bold text-blue-500 tracking-widest uppercase mb-2 block">Hardware</span>
                        <h3 class="text-xl text-white font-bold mb-2">Custom Lightsabers</h3>
                        <p class="text-zinc-400 text-sm line-clamp-2">First foray into combat-ready prop electronics. High-end wiring and physical reinforcement.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- YEAR 2024 SECTION -->
        <div class="flex flex-col md:flex-row relative h-full items-center mr-12 md:mr-32 pt-12 md:pt-0">
            <div class="md:sticky left-8 z-0 flex items-center self-stretch opacity-20 pointer-events-none mb-4 md:mb-0">
                <span class="text-[6rem] md:text-[12rem] font-black text-emerald-800 leading-none tracking-tighter mix-blend-overlay">2024</span>
            </div>

            <!-- Project 3: Top -->
            <div class="relative w-[90vw] md:w-96 flex flex-col items-center md:-mt-[24rem] group mx-0 md:mx-8 cursor-pointer mb-8 md:mb-0">
                <div class="hidden md:block w-4 h-4 rounded-full bg-purple-500 absolute bottom-[-11.5rem] shadow-[0_0_15px_rgba(168,85,247,0.5)] z-20 group-hover:scale-150 transition-transform"></div>
                <div class="hidden md:block absolute left-1/2 bottom-[-11rem] w-0.5 h-48 bg-zinc-800 z-10"></div>
                
                <div class="w-full bg-zinc-900 border border-zinc-700 rounded-2xl overflow-hidden hover:border-purple-500 transition-all duration-300 md:group-hover:-translate-y-2 shadow-xl z-30 relative">
                    <div class="absolute top-4 right-4 w-8 h-8 bg-black/50 backdrop-blur rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"><span class="text-white text-xs">⤢</span></div>
                    <div class="h-48 bg-zinc-800 flex items-center justify-center text-zinc-600"><span>[ Photo: Pressure Testing ]</span></div>
                    <div class="p-6">
                        <span class="text-xs font-bold text-purple-500 tracking-widest uppercase mb-2 block">Fabrication</span>
                        <h3 class="text-xl text-white font-bold mb-2">4th of July Tube (Proto)</h3>
                        <p class="text-zinc-400 text-sm line-clamp-2">Testing fluid dynamics in real time. Failed drastically under intense psi limits.</p>
                    </div>
                </div>
            </div>

            <!-- Project 4: Bottom -->
            <div class="relative w-[90vw] md:w-[28rem] flex flex-col items-center md:mt-[24rem] group mx-0 md:mx-8 cursor-pointer mb-8 md:mb-0">
                <div class="hidden md:block w-4 h-4 rounded-full bg-cyan-500 absolute top-[-11.5rem] shadow-[0_0_15px_rgba(6,182,212,0.5)] z-20 group-hover:scale-150 transition-transform"></div>
                <div class="hidden md:block absolute left-1/2 top-[-11rem] w-0.5 h-48 bg-zinc-800 z-10"></div>
                
                <div class="w-full bg-zinc-900 border border-zinc-700 rounded-2xl overflow-hidden hover:border-cyan-500 transition-all duration-300 md:group-hover:translate-y-2 shadow-xl z-30 relative border-l-4 border-l-cyan-500">
                    <div class="absolute top-4 right-4 w-8 h-8 bg-black/50 backdrop-blur rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"><span class="text-white text-xs">⤢</span></div>
                    <div class="h-56 bg-zinc-800 flex items-center justify-center text-zinc-600"><span>[ Video: Audio Reactive LEDs ]</span></div>
                    <div class="p-8">
                        <span class="text-xs font-bold text-cyan-500 tracking-widest uppercase mb-2 block">Hardware / Software</span>
                        <h3 class="text-2xl text-white font-bold mb-2">Cuttlefish Lights</h3>
                        <p class="text-zinc-400 text-sm line-clamp-2">MSGEQ7 band manipulation wired perfectly to a React desktop GUI.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- YEAR 2025 SECTION -->
        <div class="flex flex-col md:flex-row relative h-full items-center mr-12 md:mr-32 pt-12 md:pt-0">
            <div class="md:sticky left-8 z-0 flex items-center self-stretch opacity-20 pointer-events-none mb-4 md:mb-0">
                <span class="text-[6rem] md:text-[12rem] font-black text-blue-800 leading-none tracking-tighter mix-blend-overlay">2025</span>
            </div>

            <!-- Project 5: Top -->
            <div class="relative w-[90vw] md:w-[32rem] flex flex-col items-center md:-mt-[24rem] group mx-0 md:mx-8 cursor-pointer mb-24 md:mb-0">
                <div class="hidden md:block w-4 h-4 rounded-full bg-emerald-500 absolute bottom-[-11.5rem] shadow-[0_0_15px_rgba(16,185,129,0.5)] z-20 group-hover:scale-150 transition-transform"></div>
                <div class="hidden md:block absolute left-1/2 bottom-[-11rem] w-0.5 h-48 bg-zinc-800 z-10"></div>
                
                <div class="w-full bg-zinc-900 border border-zinc-700 rounded-2xl overflow-hidden hover:border-emerald-500 transition-all duration-300 md:group-hover:-translate-y-2 shadow-xl z-30 relative border-t-8 border-t-emerald-500">
                    <div class="absolute top-4 right-4 w-8 h-8 bg-black/50 backdrop-blur rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"><span class="text-white text-xs">⤢</span></div>
                    <div class="h-64 bg-zinc-800 flex items-center justify-center text-zinc-600"><span>[ Image: Complex Graph Dashboard ]</span></div>
                    <div class="p-8">
                        <span class="text-xs font-bold text-emerald-500 tracking-widest uppercase mb-2 block">Software Architecture</span>
                        <h3 class="text-3xl text-white font-bold mb-3">Stock Prediction Dashboard</h3>
                        <p class="text-zinc-400 text-sm line-clamp-3">Full-stack React ecosystem ingesting pure data lines to analyze and predict dividend execution drops directly from an optimized Python backend.</p>
                    </div>
                </div>
            </div>

        </div>

    </div>
  </div>

  <style>
    .CustomScrollContainer::-webkit-scrollbar { height: 12px; }
    .CustomScrollContainer::-webkit-scrollbar-track { background: #09090b; }
    .CustomScrollContainer::-webkit-scrollbar-thumb { background: #27272a; border-radius: 8px; }
    .CustomScrollContainer::-webkit-scrollbar-thumb:hover { background: #3f3f46; }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const scrollContainer = document.querySelector('.CustomScrollContainer');
      if (scrollContainer) {
        scrollContainer.addEventListener('wheel', (evt) => {
          if (window.innerWidth >= 768) {
            evt.preventDefault();
            scrollContainer.scrollLeft += evt.deltaY;
          }
        });
      }
    });
  </script>
</Layout>
