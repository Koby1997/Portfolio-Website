---
import '../styles/global.css';
---
<!doctype html>
<html lang="en" class="dark scroll-smooth">
<head>
	<meta charset="UTF-8" />
	<title>Demo 3 - Cinematic Scale</title>
</head>
<body class="bg-zinc-950 text-zinc-50 font-sans antialiased overflow-x-hidden m-0 p-0">
  <div class="absolute top-8 right-8 z-50">
    <a href="/" class="text-zinc-500 hover:text-white px-4 py-2 border border-zinc-800 rounded-lg bg-zinc-900 hover:bg-zinc-800 transition">Return to Home</a>
  </div>

  <section class="relative w-full h-screen bg-zinc-900 flex items-center overflow-hidden group">
    <div class="absolute inset-0 flex items-center justify-center opacity-[0.03] pointer-events-none select-none">
      <h1 class="text-[25vw] font-black tracking-tighter whitespace-nowrap text-white">MAKER</h1>
    </div>
    <div class="relative z-10 flex flex-col items-start w-full max-w-6xl mx-auto px-8 sm:px-16">
      <div class="w-12 h-1 bg-blue-500 mb-10"></div>
      <h2 class="text-6xl md:text-8xl font-bold leading-[1.1] tracking-tighter text-white">
        <span class="text-zinc-500">Hi, I'm</span><br/>
        K<span class="relative inline-block cursor-grab hover:scale-105 transition-transform duration-300">
          o
          <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 bg-blue-400 rounded-full shadow-[0_0_15px_#60a5fa] animate-ping opacity-75"></span>
          <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-1.5 h-1.5 bg-blue-300 rounded-full z-10"></span>
        </span>by.
      </h2>
      <p class="mt-10 text-xl sm:text-3xl text-zinc-400 max-w-2xl font-light">
        Bridging the gap between heavy engineering and high-end aesthetic design.
      </p>
    </div>
  </section>
</body>
</html>
