---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resume | Koby L.">
  <div class="max-w-4xl mx-auto py-12">
    <div class="flex justify-between items-end mb-10 border-b border-zinc-800 pb-6">
      <div>
        <h1 class="text-4xl font-bold mb-2">Resume</h1>
        <p class="text-zinc-400">Software Developer & Hardware Engineer</p>
      </div>
      <a href="#" class="px-4 py-2 bg-zinc-800 hover:bg-zinc-700 rounded-md text-sm font-medium transition-colors border border-zinc-700">
        Download PDF
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div class="md:col-span-1 space-y-8">
        <section>
          <h2 class="text-xl font-semibold mb-4 text-white">Tech Stack</h2>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-zinc-900 border border-zinc-800 rounded-full text-sm text-zinc-300">JavaScript</span>
            <span class="px-3 py-1 bg-zinc-900 border border-zinc-800 rounded-full text-sm text-zinc-300">React</span>
            <span class="px-3 py-1 bg-zinc-900 border border-zinc-800 rounded-full text-sm text-zinc-300">Astro</span>
            <span class="px-3 py-1 bg-zinc-900 border border-zinc-800 rounded-full text-sm text-zinc-300">Python</span>
            <span class="px-3 py-1 bg-zinc-900 border border-zinc-800 rounded-full text-sm text-zinc-300">C++ / Arduino</span>
          </div>
        </section>
      </div>

      <div class="md:col-span-2 space-y-10">
        <section>
          <h2 class="text-2xl font-semibold mb-6 text-white">Selected Experience</h2>
          
          <div class="mb-8">
            <div class="flex justify-between items-start mb-2">
              <h3 class="text-xl font-medium text-blue-400">Software Development Agency</h3>
              <span class="text-zinc-500 text-sm">Present</span>
            </div>
            <p class="text-zinc-300 mb-2">Founder & Lead Developer</p>
            <ul class="list-disc list-inside text-zinc-400 space-y-1 text-sm">
              <li>Building high-performance, SEO-optimized web applications for service-based businesses.</li>
              <li>Utilizing React, Next.js, and Astro to deliver tailored client solutions.</li>
            </ul>
          </div>
        </section>
      </div>
    </div>
  </div>
</Layout>
