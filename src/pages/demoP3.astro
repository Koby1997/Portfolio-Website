---
import '../styles/global.css';

const items = [
    { title: 'The Last of Us', cat: 'GAMING ARCHIVE', img: 'from-zinc-800 to-green-950' },
    { title: 'Interstellar', cat: 'NOLAN CINEMA', img: 'from-zinc-800 to-blue-950' },
    { title: 'Spider-Man', cat: 'GAMING ARCHIVE', img: 'from-zinc-800 to-red-950' },
    { title: 'Magic: The Gathering', cat: 'TABLETOP TACTICS', img: 'from-zinc-800 to-purple-950' },
    { title: 'Rock Climbing', cat: 'KINETIC PURSUITS', img: 'from-zinc-800 to-orange-950' },
    { title: 'Tenet', cat: 'NOLAN CINEMA', img: 'from-zinc-800 to-cyan-950' },
    { title: 'Ghost of Yōtei', cat: 'GAMING ARCHIVE', img: 'from-zinc-800 to-rose-950' },
    { title: 'Volleyball', cat: 'KINETIC PURSUITS', img: 'from-zinc-800 to-emerald-950' }
];
---
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>P3. 3D Flow</title>
    <style>
        .perspective-container {
            perspective: 1200px;
        }
        .carousel {
            transform-style: preserve-3d;
            transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        .card {
            transform-style: preserve-3d;
            transition: all 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
            -webkit-box-reflect: below 2px linear-gradient(transparent, transparent, rgba(0,0,0,0.4));
        }
    </style>
</head>
<body class="bg-zinc-950 text-white overflow-hidden w-screen h-screen m-0 p-0 font-sans select-none flex flex-col pt-12">
    
    <!-- Header Exit -->
    <div class="absolute top-8 left-8 z-50 mix-blend-difference pointer-events-auto">
        <a href="/" class="text-white font-mono tracking-[0.2em] text-xs hover:text-rose-400 transition-colors uppercase pb-2 border-b border-white/20 hover:border-rose-400">
            &larr; Exit Gallery
        </a>
    </div>

    <!-- Interface Indicators -->
    <div class="w-full text-center mt-12 z-10 pointer-events-none">
        <h1 class="text-4xl font-light tracking-[0.3em] uppercase text-zinc-300">Media Gallery</h1>
        <p class="text-zinc-500 font-mono text-xs tracking-widest mt-4">USE ARROW KEYS OR SWIPE TO ROTATE</p>
    </div>

    <!-- 3D Environment -->
    <div class="flex-grow w-full relative perspective-container flex items-center justify-center overflow-hidden">
        
        <!-- The Rotator Hub -->
        <div id="carousel" class="absolute w-[300px] h-[400px] carousel" style="transform: rotateY(0deg);">
            
            {items.map((item, i) => {
                const angle = (i * 360) / items.length;
                return (
                    <div class={`card absolute top-0 left-0 w-full h-full rounded-2xl bg-gradient-to-br ${item.img} border border-zinc-700 shadow-2xl flex flex-col justify-end p-6 cursor-pointer hover:border-white transition-colors group`}
                         style={`transform: rotateY(${angle}deg) translateZ(450px);`}>
                         
                         <!-- Card Glass Blur -->
                         <div class="absolute inset-0 rounded-2xl bg-black/20 group-hover:bg-transparent transition-colors z-0 pointer-events-none"></div>

                         <div class="relative z-10">
                            <span class="font-mono text-xs tracking-[0.2em] text-white/50 uppercase block mb-2 drop-shadow-md">{item.cat}</span>
                            <h2 class="text-2xl font-black text-white tracking-tighter drop-shadow-xl">{item.title}</h2>
                         </div>
                    </div>
                )
            })}
            
        </div>
    </div>

    <script define:vars={{ count: items.length }}>
        // Logic bound immediately since it's inline in purely html layout
        const carousel = document.getElementById('carousel');
        let currentIndex = 0;
        const theta = 360 / count;

        function rotateCarousel() {
            const angle = currentIndex * -theta;
            carousel.style.transform = `rotateY(${angle}deg)`;
        }

        // Bind Keyboard Support
        window.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowRight') {
                currentIndex++;
                rotateCarousel();
            } else if (e.key === 'ArrowLeft') {
                currentIndex--;
                rotateCarousel();
            }
        });

        // Bind Mouse Wheel Support
        window.addEventListener('wheel', (e) => {
            if (e.deltaY > 0) {
                currentIndex++;
            } else {
                currentIndex--;
            }
            rotateCarousel();
        }, { passive: true });

        // Bind touch swipe support
        let startX = 0;
        window.addEventListener('touchstart', e => startX = e.touches[0].clientX);
        window.addEventListener('touchend', e => {
            const endX = e.changedTouches[0].clientX;
            if (startX - endX > 50) {
                currentIndex++; rotateCarousel();
            } else if (endX - startX > 50) {
                currentIndex--; rotateCarousel();
            }
        });

    </script>
</body>
</html>
