---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Demo 4: Snap Carousel">
  <div class="max-w-5xl mx-auto py-12 px-4 text-center">
    <h1 class="text-3xl font-bold mb-4">Style 4: The Snap Carousel</h1>
    <p class="text-zinc-400 mb-8 max-w-2xl mx-auto">Forces the user to focus on one single event at a time. Scroll sideways—the browser will magnetically "snap" the next event perfectly into the center of your screen.</p>
  </div>
  
  <div class="w-full overflow-x-auto pb-12 snap-x snap-mandatory custom-scrollbar flex items-center h-[70vh] min-h-[500px]">
    
    <!-- Padding blocks so the first/last item can actually sit perfectly in the center -->
    <div class="w-[5vw] md:w-[20vw] flex-shrink-0"></div> 

    <!-- Card 1 -->
    <div class="snap-center shrink-0 w-[90vw] md:w-[60vw] h-full max-h-[600px] border border-zinc-800 bg-zinc-900 rounded-3xl p-8 md:p-16 mx-4 flex flex-col shadow-2xl relative overflow-hidden group">
      <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/10 to-transparent"></div>
      <h2 class="text-6xl text-emerald-500 font-bold mb-4 font-mono z-10 opacity-30 absolute top-8 right-8">2022</h2>
      
      <div class="z-10 flex-grow flex flex-col justify-center">
          <h3 class="text-4xl text-white mb-6 font-serif">Ideation Phase</h3>
          <p class="text-zinc-400 text-xl md:text-2xl leading-relaxed">The raw math phase. Understanding fluid dynamics and pressure limits before buying a single piece of PVC.</p>
      </div>
      
      <div class="z-10 text-emerald-800 font-bold uppercase tracking-widest text-sm">&larr; Swipe or Scroll Horizontal &rarr;</div>
    </div>

    <!-- Card 2 -->
    <div class="snap-center shrink-0 w-[90vw] md:w-[60vw] h-full max-h-[600px] border border-zinc-800 bg-zinc-900 rounded-3xl p-8 md:p-16 mx-4 flex flex-col shadow-2xl relative overflow-hidden group">
      <div class="absolute inset-0 bg-gradient-to-br from-blue-500/10 to-transparent"></div>
      <h2 class="text-6xl text-blue-500 font-bold mb-4 font-mono z-10 opacity-30 absolute top-8 right-8">2023</h2>
      
      <div class="z-10 flex-grow flex flex-col justify-center">
          <h3 class="text-4xl text-white mb-6 font-serif">Fabrication</h3>
          <p class="text-zinc-400 text-xl md:text-2xl leading-relaxed">Machining the core parts. Putting the math to the test in the real world.</p>
      </div>
    </div>

    <!-- Card 3 -->
    <div class="snap-center shrink-0 w-[90vw] md:w-[60vw] h-full max-h-[600px] border border-zinc-800 bg-zinc-950 rounded-3xl p-8 md:p-16 mx-4 flex flex-col shadow-[0_0_50px_rgba(16,185,129,0.1)] relative overflow-hidden border-b-8 border-b-emerald-600">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent to-emerald-900/20"></div>
      <h2 class="text-6xl text-emerald-600 font-bold mb-4 font-mono z-10 opacity-30 absolute top-8 right-8">2024</h2>
      
      <div class="z-10 flex-grow flex flex-col justify-center">
          <h3 class="text-5xl text-white mb-6 font-serif">Ignition</h3>
          <p class="text-zinc-300 text-xl md:text-2xl leading-relaxed">The final test phase. Consistent payload delivery verified.</p>
      </div>
    </div>

    <div class="w-[5vw] md:w-[20vw] flex-shrink-0"></div> 
  </div>

  <script>
    const scrollContainer = document.querySelector('.custom-scrollbar');
    if (scrollContainer) {
      scrollContainer.addEventListener('wheel', (evt) => {
        if (window.innerWidth >= 768) {
          evt.preventDefault();
          scrollContainer.scrollLeft += evt.deltaY;
        }
      });
    }
  </script>
</Layout>
