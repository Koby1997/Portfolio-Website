---
import '../styles/global.css';

// For a Constellation, we position Hub nodes and Branch nodes absolute.
// This requires generating hardcoded lines (SVG).
const nodes = [
    { id: 'hub1', name: 'THE_NARRATIVE', x: 25, y: 30, type: 'hub', color: 'bg-blue-600' },
    { id: 'hub2', name: 'THE_KINETIC', x: 75, y: 40, type: 'hub', color: 'bg-orange-600' },
    { id: 'hub3', name: 'THE_TACTIC', x: 50, y: 70, type: 'hub', color: 'bg-purple-600' },

    // Narrative Branches
    { id: 'l1', name: 'Spider-Man', x: 15, y: 15, parent: 'hub1' },
    { id: 'l2', name: 'Tenet', x: 35, y: 10, parent: 'hub1' },
    { id: 'l3', name: 'Interstellar', x: 10, y: 40, parent: 'hub1' },

    // Kinetic Branches
    { id: 'l4', name: 'Volleyball', x: 85, y: 25, parent: 'hub2' },
    { id: 'l5', name: 'Lacrosse', x: 90, y: 55, parent: 'hub2' },
    { id: 'l6', name: 'Rock Climbing', x: 65, y: 20, parent: 'hub2' },

    // Tactic Branches
    { id: 'l7', name: 'MtG', x: 35, y: 85, parent: 'hub3' },
    { id: 'l8', name: 'Poker', x: 65, y: 90, parent: 'hub3' },
    { id: 'l9', name: 'Board Games', x: 50, y: 95, parent: 'hub3' },

    // Cross-Ecosystems (Bridges)
    { id: 'b1', name: 'Escape Rooms', x: 65, y: 55, parent: 'hub2', parent2: 'hub3' },
    { id: 'b2', name: 'Star Wars', x: 35, y: 50, parent: 'hub1', parent2: 'hub3' }
];

---

<html lang="en" class="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>P7. Constellation Web</title>
</head>
<body class="bg-zinc-950 text-white overflow-hidden w-screen h-screen m-0 p-0 font-sans cursor-crosshair">
    
    <div class="fixed top-8 left-8 z-50">
        <a href="/" class="text-white font-mono tracking-[0.2em] text-xs hover:text-white/50 uppercase pb-2 border-b border-white/20">&larr; Matrix</a>
    </div>

    <!-- The Node Network -->
    <div class="relative w-full h-full">

        <!-- SVG to draw connecting branch lines -->
        <svg class="absolute inset-0 w-full h-full pointer-events-none z-0" id="svg-canvas" preserveAspectRatio="none">
            {nodes.map(node => {
                if (!node.parent) return null;
                const parentNode = nodes.find(n => n.id === node.parent);
                return (
                    <line 
                        x1={`${parentNode.x}%`} y1={`${parentNode.y}%`} 
                        x2={`${node.x}%`} y2={`${node.y}%`} 
                        stroke="rgba(255,255,255,0.1)" stroke-width="2" 
                    />
                )
            })}
            {nodes.map(node => {
                if (!node.parent2) return null;
                const parentNode = nodes.find(n => n.id === node.parent2);
                return (
                    <line 
                        x1={`${parentNode.x}%`} y1={`${parentNode.y}%`} 
                        x2={`${node.x}%`} y2={`${node.y}%`} 
                        stroke="rgba(255,255,255,0.1)" stroke-width="2" stroke-dasharray="5,5"
                    />
                )
            })}
        </svg>

        <!-- HTML Nodes overlaid perfectly onto SVG coordinates using CSS Left/Top -->
        {nodes.map(node => (
            <div 
                class={`absolute group w-max transform -translate-x-1/2 -translate-y-1/2 flex items-center justify-center z-10 transition-transform duration-500 hover:scale-125 ${node.type === 'hub' ? 'pointer-events-auto' : 'pointer-events-auto'}`}
                style={`left: ${node.x}%; top: ${node.y}%;`}
            >
                {node.type === 'hub' ? (
                    <div class="relative flex items-center justify-center">
                        <div class={`absolute rounded-full w-24 h-24 ${node.color} blur-[50px] opacity-50`}></div>
                        <div class={`w-6 h-6 rounded-full border-4 border-white ${node.color} shadow-[0_0_20px_white]`}></div>
                        <span class="absolute mt-20 font-black tracking-[0.3em] text-2xl opacity-70 group-hover:opacity-100 transition-opacity drop-shadow-xl">{node.name}</span>
                    </div>
                ) : (
                    <div class="relative flex items-center group/leaf px-4 py-2">
                        <div class="w-3 h-3 bg-zinc-600 group-hover/leaf:bg-white rounded-full transition-colors z-20"></div>
                        <span class="ml-4 font-mono text-sm tracking-widest uppercase text-zinc-500 group-hover/leaf:text-white transition-colors bg-zinc-950/80 px-2 py-1 rounded select-none shadow">
                            {node.name}
                        </span>
                    </div>
                )}
            </div>
        ))}

    </div>

</body>
</html>
