---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
allProjects.sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

const projectsByYear = {};
allProjects.forEach(project => {
    const year = project.data.pubDate.getFullYear();
    if (!projectsByYear[year]) projectsByYear[year] = [];
    projectsByYear[year].push(project);
});

const years = Object.keys(projectsByYear).sort();
const postYears = Array.from({ length: 24 }, (_, i) => 1993 + i);

const parallaxHues = Array.from({ length: 100 }, (_, i) => ({
    top: i % 2 === 0 ? Math.floor(Math.random() * 20) + 10 : Math.floor(Math.random() * 20) + 60,
    left: i * 15 + 30, // Spaced every 15vw covering 1500vw
    size: Math.floor(Math.random() * 15) + 20,
    blur: Math.floor(Math.random() * 4) + 6
}));

const getColorConfig = (category) => {
   switch(category.toLowerCase()) {
       case 'software': return { text: 'text-emerald-500', bg: 'bg-emerald-500', borderHover: 'hover:border-emerald-500', shadow: 'shadow-[0_0_15px_rgba(16,185,129,0.5)]' };
       case 'hardware': return { text: 'text-blue-500', bg: 'bg-blue-500', borderHover: 'hover:border-blue-500', shadow: 'shadow-[0_0_15px_rgba(59,130,246,0.5)]' };
       case 'event': return { text: 'text-orange-500', bg: 'bg-orange-500', borderHover: 'hover:border-orange-500', shadow: 'shadow-[0_0_15px_rgba(249,115,22,0.5)]' };
       case 'engineering': return { text: 'text-cyan-500', bg: 'bg-cyan-500', borderHover: 'hover:border-cyan-500', shadow: 'shadow-[0_0_15px_rgba(6,182,212,0.5)]' };
       case 'milestone': return { text: 'text-purple-500', bg: 'bg-purple-500', borderHover: 'hover:border-purple-500', shadow: 'shadow-[0_0_15px_rgba(168,85,247,0.5)]' };
       default: return { text: 'text-zinc-500', bg: 'bg-zinc-500', borderHover: 'hover:border-zinc-500', shadow: 'shadow-[0_0_15px_rgba(113,113,122,0.5)]' };
   }
}
---

<!doctype html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Timeline | Koby L.</title>
    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
                "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
            }
        }
    </script>
    <ClientRouter fallback="swap" />
</head>
<body class="bg-zinc-950 text-zinc-50 h-screen w-screen overflow-hidden flex flex-col font-sans antialiased">
    
    <!-- Black overlay for cinematic transitions -->
    <div id="blackout-overlay" class="fixed inset-0 bg-black opacity-0 pointer-events-none z-[100] transition-opacity duration-[1200ms] ease-in-out"></div>
    
    <!-- Timeline Exit Button -->
    <div id="timeline-exit-container" class="fixed top-8 left-8 z-50 opacity-0 pointer-events-none transition-opacity duration-500 group">
        <a href="/" class="flex items-center gap-3 px-6 py-2.5 bg-zinc-950/40 backdrop-blur-md border border-white/10 rounded-full text-white/70 hover:text-white hover:bg-zinc-900/60 hover:border-white/30 transition-all duration-300 shadow-xl shadow-black/20">
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:-translate-x-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            <span class="font-sans text-sm font-medium tracking-widest uppercase">Home</span>
        </a>
    </div>

    <!-- Pure Timeline Container (No vertical scrolling allowed on page) -->
    <main class="flex-grow w-full relative flex items-center bg-gradient-to-br from-zinc-950 via-zinc-950 to-zinc-900 overflow-hidden">
        
        <!-- The Parallax Background Layer -->
        <div id="timeline-parallax-bg" class="absolute top-0 left-0 h-full w-[4000vw] z-0 pointer-events-none overflow-hidden will-change-transform translate-x-0">
            <!-- Simulated Demo-3 Background Base (Overlapping Blue & Teal to brighten the Violet Origin Point) -->
            <!-- Central Aura (Home Screen) -->
            <div class="absolute top-1/4 left-[50vw] -translate-x-1/2 bg-blue-500/10 rounded-full mix-blend-screen transition-opacity duration-1000" style="width: clamp(30rem, 35vw, 80rem); height: clamp(30rem, 35vw, 80rem); filter: blur(clamp(100px, 8vw, 300px));"></div>
            <!-- Timeline Aura (Home Screen) -->
            <div class="absolute top-1/3 left-[115vw] bg-violet-500/20 rounded-full mix-blend-screen" style="width: clamp(30rem, 35vw, 80rem); height: clamp(30rem, 35vw, 80rem); filter: blur(clamp(100px, 8vw, 300px));"></div>
            <!-- Resume Aura (Home Screen) -->
            <div class="absolute bottom-[-15%] left-[10vw] bg-teal-500/10 rounded-full mix-blend-screen" style="width: clamp(30rem, 35vw, 80rem); height: clamp(30rem, 35vw, 80rem); filter: blur(clamp(100px, 8vw, 300px));"></div>

            <!-- Extended scattered violet hues matching Home page Demo 3 transition -->
            {parallaxHues.map((hue, i) => (
                <div 
                    class="absolute bg-violet-500/10 rounded-full mix-blend-screen"
                    style={`top: ${hue.top}%; left: ${hue.left}vw; width: clamp(20rem, ${hue.size}vw, 80rem); height: clamp(20rem, ${hue.size}vw, 80rem); filter: blur(clamp(100px, ${hue.blur}vw, 300px));`}
                ></div>
            ))}
        </div>

        <!-- Fixed Floating Header -->
        <div id="timeline-floating-header" class="absolute top-24 left-4 md:left-12 z-40 pointer-events-none drop-shadow-[0_4px_20px_rgba(0,0,0,1)] mix-blend-screen hidden md:block opacity-0 transition-opacity duration-1000">
            <h1 class="text-4xl md:text-5xl font-black mb-1 tracking-tighter text-white">The Timeline</h1>
            <p class="text-zinc-300 max-w-sm text-sm leading-relaxed"><span class="text-violet-400 font-bold block">(Click on an event to view the breakdown).</span></p>
        </div>
        
        <!-- The Horizontal Scroll Canvas -->
        <div id="timeline-container" class="w-full h-full overflow-x-hidden overflow-y-hidden flex items-center CustomScrollContainer relative">
            <div class="flex flex-row items-center h-full w-max mt-24 md:mt-0 relative">
                <!-- The Master Horizontal Line -->
                <div class="absolute top-1/2 left-[100vw] w-[calc(100%-100vw)] h-[2px] bg-zinc-800 -translate-y-1/2 z-0 hidden md:block"></div>

                <!-- 1. The Unified Home Screen (Demo 3) -->
                <div id="unified-home-screen" class="w-[100vw] h-full shrink-0 flex flex-col justify-center relative z-20 px-4 md:px-0">
                    <div class="w-full max-w-6xl mx-auto px-6 lg:px-8 flex flex-col justify-center h-full pt-12">
                        
                        <div class="max-w-4xl mb-16 text-center mx-auto">
                        <h1 id="cinematic-koby-text" class="text-7xl md:text-[7rem] font-bold text-white mb-6 tracking-tighter relative z-[60]">
                            <span class="cinematic-extra-text transition-opacity duration-[800ms]">Hi, I'm&nbsp;</span><span id="cinematic-koby-only" class="inline-block transition-transform duration-[800ms] ease-in-out origin-center">K<span id="zoom-target-o" class="relative inline-block origin-center">o</span>by</span><span class="cinematic-extra-text transition-opacity duration-[800ms]">.</span>
                        </h1>
                        <p class="text-2xl text-zinc-400 font-light leading-relaxed">
                            I'm just a fun guy trying to make cool things.
                        </p>
                        </div>

                        <!-- The 3 Evenly Spaced Gateways -->
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        
                        <a href="/resume" class="group relative rounded-2xl bg-zinc-900/20 border border-zinc-800/40 hover:bg-zinc-900/60 hover:border-teal-500/40 transition-all duration-500 p-8 pt-10 pb-10 flex flex-col justify-start backdrop-blur-2xl">
                            <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-teal-400 transition-colors">The Credentials</h3>
                            <p class="text-zinc-500 font-light leading-relaxed group-hover:text-zinc-300 transition-colors">The professional breakdown. Stack, tech skills, past experience, and official resume downloads.</p>
                        </a>

                        <a href="/brain" id="brain-link-trigger" class="group relative rounded-2xl bg-zinc-900/20 border border-zinc-800/40 hover:bg-zinc-900/60 hover:border-blue-500/40 transition-all duration-500 p-8 pt-10 pb-10 flex flex-col justify-start backdrop-blur-2xl z-20">
                            <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-blue-400 transition-colors">The Neural Core</h3>
                            <p class="text-zinc-500 font-light leading-relaxed group-hover:text-zinc-300 transition-colors">An interactive 3D map of my mindset. See exactly how my hobbies and engineering principles connect.</p>
                        </a>

                        <a href="#" id="unified-timeline-trigger" class="group relative rounded-2xl bg-zinc-900/20 border border-zinc-800/40 hover:bg-zinc-900/60 hover:border-violet-500/40 transition-all duration-500 p-8 pt-10 pb-10 flex flex-col justify-start backdrop-blur-2xl">
                            <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-violet-400 transition-colors">The Timeline</h3>
                            <p class="text-zinc-500 font-light leading-relaxed group-hover:text-zinc-300 transition-colors">A chronological journey logging my past projects, milestones, logic builds, and personal history.</p>
                        </a>

                        </div>
                    </div>
                </div>

                <!-- 2. Cinematic Intro Runway (The Void 0-1997) -->
                <div id="cinematic-runway" class="flex-row relative h-full items-center mr-0 md:mr-32 flex">
                    <!-- The Sticky Void Counter -->
                    <div id="cinematic-sticky-counter-container" class="hidden absolute top-0 left-0 w-[800vw] h-full flex-row items-center pointer-events-none z-50 transition-opacity duration-300">
                        <div class="sticky left-8 z-0 flex items-center opacity-20 pointer-events-none">
                            <span id="cinematic-sticky-counter" class="text-[8rem] md:text-[14rem] font-black text-zinc-600 leading-none tracking-tighter mix-blend-overlay">0</span>
                        </div>
                    </div>
                    
                    <div class="w-[800vw] h-full shrink-0 relative flex items-center pointer-events-none"></div>

                    <!-- Highway 1997 to 2017 mapped strictly -->
                    {postYears.map(year => (
                        <div class="flex flex-row relative h-full items-center mr-0 md:mr-32 shrink-0 min-w-[40vw] w-max">
                            <div class="sticky left-8 z-0 flex items-center self-stretch opacity-20 pointer-events-none mb-0">
                                <span class="text-[8rem] md:text-[14rem] font-black text-zinc-600 leading-none tracking-tighter mix-blend-overlay">{year}</span>
                            </div>
                            
                            {year === 1997 && (
                                <div id="baby-1997-marker" class="relative w-[85vw] md:w-80 shrink-0 flex flex-col items-center group mx-4 md:mx-8 cursor-pointer transition-transform md:-translate-y-[20vh] z-30">
                                    <div class="hidden md:block w-5 h-5 rounded-full bg-violet-600 absolute shadow-[0_0_15px_rgba(139,92,246,0.5)] z-20 bottom-[-4.5rem]"></div>
                                    <div class="hidden md:block absolute left-1/2 w-[2px] h-16 bg-zinc-800 z-10 bottom-[-4rem]"></div>
                                    
                                    <div class="w-full bg-zinc-900 border border-violet-800 rounded-2xl overflow-hidden shadow-2xl z-30 relative backdrop-blur-md pb-6 group-hover:scale-[1.02] transition-transform">
                                        <div class="aspect-video bg-zinc-800 flex flex-col items-center justify-center text-zinc-600 font-mono text-sm relative">
                                            <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors z-10 pointer-events-none"></div>
                                            <img src="/assets/projects/baby-picture/BabyKoby.jpg" alt="Baby Koby 1997" class="w-full h-full object-cover opacity-100" />
                                        </div>
                                        <div class="p-6 h-full">
                                            <h3 class="text-xl text-violet-400 font-bold mb-2">System Initialized</h3>
                                            <p class="text-zinc-400 text-sm">Hardcoded into physical reality. A fresh node on the network.</p>
                                        </div>
                                    </div>
                                    
                                    <div id="baby-hidden-message" class="absolute top-[140%] w-max left-1/2 -translate-x-1/2 opacity-0 translate-y-6 transition-all duration-1000 ease-out z-40">
                                        <p class="text-zinc-400 text-2xl md:text-3xl font-semibold italic tracking-wide">... Not far enough. Let's keep going.</p>
                                    </div>
                                </div>
                            )}
                        </div>
                    ))}
                </div>

                {years.map((yearStr, idx) => (
                    <div id={idx === 0 ? "real-timeline-start" : undefined} class="flex flex-row relative h-full items-center mr-0 md:mr-32">
                        <!-- The Sticky Year Header -->
                        <div class="sticky left-8 z-0 flex items-center self-stretch opacity-20 pointer-events-none mb-0">
                            <span class="text-[8rem] md:text-[14rem] font-black text-zinc-600 leading-none tracking-tighter mix-blend-overlay">{yearStr}</span>
                        </div>

                        {projectsByYear[yearStr].map((project, idx) => {
                            const isTop = idx % 2 === 0;
                            const primaryCategory = project.data.categories[0] || 'Unknown';
                            const colors = getColorConfig(primaryCategory);
                            
                            return (
                                <a href={`/projects/${project.id}`} class={`relative w-[85vw] md:w-80 shrink-0 flex flex-col items-center group mx-4 md:mx-8 cursor-pointer transition-transform ${isTop ? 'md:-translate-y-[20vh]' : 'md:translate-y-[20vh]'}`}>
                                    
                                    <!-- Node & Trunk Line (Desktop Only) -->
                                    <div class={`hidden md:block w-5 h-5 rounded-full ${colors.bg} absolute ${colors.shadow} z-20 transition-transform group-hover:scale-150 ${isTop ? 'bottom-[-4.5rem]' : 'top-[-4.5rem]'}`}></div>
                                    <div class={`hidden md:block absolute left-1/2 w-[2px] h-16 bg-zinc-800 z-10 ${isTop ? 'bottom-[-4rem]' : 'top-[-4rem]'}`}></div>
                                    
                                    <!-- The Teaser Card -->
                                    <div 
                                        transition:name={`project-box-${project.id}`}
                                        class={`w-full bg-zinc-900 border border-zinc-700 rounded-2xl overflow-hidden ${colors.borderHover} transition-all duration-300 shadow-2xl z-30 relative group-hover:scale-[1.02]`}
                                    >
                                        
                                        <div class="aspect-video bg-zinc-800 flex items-center justify-center text-zinc-700 relative overflow-hidden font-mono text-xs origin-center">
                                            <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors z-10 pointer-events-none"></div>
                                            {project.data.coverImage ? (
                                                /\.(mp4|webm|mov)$/i.test(project.data.coverImage) ? (
                                                    <video 
                                                        src={project.data.coverImage} 
                                                        autoplay loop muted playsinline 
                                                        class="w-full h-full object-cover opacity-100" 
                                                    ></video>
                                                ) : (
                                                    <img 
                                                        src={project.data.coverImage} 
                                                        alt={project.data.title} 
                                                        class="w-full h-full object-cover opacity-100" 
                                                    />
                                                )
                                            ) : (
                                                <span>[ {primaryCategory.toUpperCase()} VISUAL ]</span>
                                            )}
                                        </div>
                                        
                                        <div class="p-6 relative bg-zinc-900">
                                            <div class="flex flex-wrap gap-x-3 gap-y-1 mb-3">
                                                {project.data.categories.map((cat) => {
                                                    const subColors = getColorConfig(cat);
                                                    return <span class={`text-[10px] font-bold ${subColors.text} tracking-widest uppercase flex items-center`}><span class={`w-1 h-1 rounded-full ${subColors.bg} mr-1.5`}></span>{cat}</span>;
                                                })}
                                            </div>
                                            <h3 class="text-xl text-white font-bold mb-3 inline-block whitespace-nowrap">
                                                {project.data.title}
                                            </h3>
                                            <p class="text-zinc-400 text-sm line-clamp-3">{project.data.description}</p>
                                        </div>
                                    </div>
                                </a>
                            );
                        })}
                    </div>
                ))}
                
            </div>
        </div>
    </main>

    <style>
        .CustomScrollContainer::-webkit-scrollbar { height: 12px; }
        .CustomScrollContainer::-webkit-scrollbar-track { background: #09090b; }
        .CustomScrollContainer::-webkit-scrollbar-thumb { background: #27272a; border-radius: 8px; }
        .CustomScrollContainer::-webkit-scrollbar-thumb:hover { background: #3f3f46; }
    </style>

    <script>
        // Store scroll position seamlessly before jumping back/forward
        document.addEventListener('astro:before-preparation', () => {
            const timeline = document.getElementById('timeline-container');
            if (timeline) {
                sessionStorage.setItem('timeline_scroll', timeline.scrollLeft.toString());
            }
        });

        // Restore scroll BEFORE the view transition calculates element bounding boxes
        document.addEventListener('astro:after-swap', () => {
            const timeline = document.getElementById('timeline-container');
            if (timeline) {
                const savedScroll = sessionStorage.getItem('timeline_scroll');
                if (savedScroll) {
                    timeline.scrollLeft = parseFloat(savedScroll);
                }
            }
        });

        document.addEventListener('astro:page-load', () => {
        const scrollContainer = document.querySelector('.CustomScrollContainer');
        const parallaxBg = document.getElementById('timeline-parallax-bg');
        if (scrollContainer) {
            
            let isAnimating = false;
            let isRewindingHome = false;
            let timelineActive = false;
            let currentScroll = scrollContainer.scrollLeft;
            let targetScroll = scrollContainer.scrollLeft;
            let scrollLimitMin = 0;

            const timelineTrigger = document.getElementById('unified-timeline-trigger');
            const homeScreen = document.getElementById('unified-home-screen');
            const runway = document.getElementById('cinematic-runway');
            const realStart = document.getElementById('real-timeline-start');
            const cinematicStickyCounter = document.getElementById('cinematic-sticky-counter');
            const floatingHeader = document.getElementById('timeline-floating-header');
            const exitContainer = document.getElementById('timeline-exit-container');

            // Force session cache clear so the user can infinitely test
            sessionStorage.removeItem('timeline_locked');

            // If we restored scroll state and are already past the runway, activate timeline mode immediately
            if (currentScroll > 0) {
                if (realStart && currentScroll >= realStart.offsetLeft - 100) {
                    scrollLimitMin = realStart.offsetLeft;
                    timelineActive = true;
                    if (floatingHeader) {
                        floatingHeader.classList.remove('opacity-0');
                        floatingHeader.classList.add('opacity-100');
                    }
                    if (exitContainer) {
                        exitContainer.classList.remove('opacity-0', 'pointer-events-none');
                        exitContainer.classList.add('opacity-100', 'pointer-events-auto');
                    }
                }
                if (parallaxBg) parallaxBg.style.transform = `translateX(${-currentScroll * 0.08}px)`;
                sessionStorage.removeItem('timeline_scroll'); // clear it so fresh loads start at 0
            }

            // Removed explicit scroll reset to 0 so restored scroll state is preserved.

            if (timelineTrigger) {
                timelineTrigger.addEventListener('click', (e) => {
                    e.preventDefault();
                    
                    scrollContainer.style.pointerEvents = 'none';
                    if(cinematicStickyCounter) {
                        document.getElementById('cinematic-sticky-counter-container').style.display = 'flex';
                        document.getElementById('cinematic-sticky-counter-container').style.opacity = '1';
                    }
                    
                    if (floatingHeader) {
                        floatingHeader.classList.remove('opacity-0');
                        floatingHeader.classList.add('opacity-100');
                    }
                    if (exitContainer) {
                        exitContainer.classList.remove('opacity-0', 'pointer-events-none');
                        exitContainer.classList.add('opacity-100', 'pointer-events-auto');
                    }

                    const babyMarker = document.getElementById('baby-1997-marker');
                    const getOffsetLeft = (el) => {
                        let offset = 0;
                        while(el && el !== scrollContainer && el !== document.body) {
                            offset += el.offsetLeft;
                            el = el.offsetParent;
                        }
                        return offset;
                    };
                    const pos1997 = getOffsetLeft(babyMarker) - (window.innerWidth / 2) + (babyMarker.offsetWidth / 2); 
                    const easeInOutCubic = (t) => t < .5 ? 4 * t * t * t : (t - 1) * (2 * t - 2) * (2 * t - 2) + 1;

                    const duration1 = 3000; 
                    let startTime = performance.now();
                    
                    const animatePhase1 = (time) => {
                        let t = (time - startTime) / duration1;
                        if (t > 1) t = 1;
                        
                        const flatT = t * 0.95;
                        const easedT = easeInOutCubic(flatT) / easeInOutCubic(0.95);
                        scrollContainer.scrollLeft = easedT * pos1997;
                        
                        if(cinematicStickyCounter) {
                            const runwayWidth = window.innerWidth * 8;
                            let counterVal = Math.floor((scrollContainer.scrollLeft / runwayWidth) * 1993);
                            if (counterVal > 1992) counterVal = 1992;
                            cinematicStickyCounter.innerText = counterVal;
                        }
                        
                        if(parallaxBg) parallaxBg.style.transform = `translateX(${-scrollContainer.scrollLeft * 0.08}px)`;

                        if (t < 1) {
                            requestAnimationFrame(animatePhase1);
                        } else {
                            if(cinematicStickyCounter) {
                                document.getElementById('cinematic-sticky-counter-container').style.opacity = '0';
                                setTimeout(() => document.getElementById('cinematic-sticky-counter-container').style.display = 'none', 300);
                            }
                            startPhase1_5(); 
                        }
                    };
                    
                    const startPhase1_5 = () => {
                        startTime = performance.now();
                        const duration1_5 = 3500;
                        const startPos = scrollContainer.scrollLeft;
                        const crawlDistance = window.innerWidth * 0.15;
                        
                        const msg = document.getElementById('baby-hidden-message');
                        if (msg) {
                            msg.style.opacity = '1';
                            msg.style.transform = 'translateY(0) translateX(-50%)';
                        }
                        
                        const animatePhase1_5 = (time) => {
                            let t = (time - startTime) / duration1_5;
                            if (t > 1) t = 1;
                            
                            const currentS = startPos + (t * crawlDistance);
                            scrollContainer.scrollLeft = currentS;
                            if(parallaxBg) parallaxBg.style.transform = `translateX(${-currentS * 0.08}px)`;
                            
                            if (t < 1) {
                                requestAnimationFrame(animatePhase1_5);
                            } else {
                                startPhase2();
                            }
                        };
                        requestAnimationFrame(animatePhase1_5);
                    };
                    
                    const startPhase2 = () => {
                        startTime = performance.now();
                        const duration2 = 2800; // Reverted back to 2800
                        const startPos = scrollContainer.scrollLeft;
                        const endPos = realStart.offsetLeft;
                        const distance = endPos - startPos;
                        
                        const easeInOutQuint = (t) => t < .5 ? 16 * t * t * t * t * t : 1 - Math.pow(-2 * t + 2, 5) / 2;
                        
                        const animatePhase2 = (time) => {
                            let t = (time - startTime) / duration2;
                            if (t > 1) t = 1;
                            
                            const startVal = easeInOutQuint(0.15);
                            const flatT = 0.15 + (t * 0.85);
                            const easedT = (easeInOutQuint(flatT) - startVal) / (1 - startVal);
                            
                            const currentS = startPos + (easedT * distance);
                            scrollContainer.scrollLeft = currentS;
                            
                            if(parallaxBg) parallaxBg.style.transform = `translateX(${-currentS * 0.08}px)`;

                            if (t < 1) {
                                requestAnimationFrame(animatePhase2);
                            } else {
                                scrollLimitMin = currentS;
                                scrollContainer.scrollLeft = currentS; 
                                currentScroll = currentS;
                                targetScroll = currentS;
                                timelineActive = true;
                                scrollContainer.style.pointerEvents = 'auto'; 
                            }
                        };
                        requestAnimationFrame(animatePhase2);
                    };

                    requestAnimationFrame(animatePhase1);
                });
            }

            const updateScroll = () => {
                currentScroll += (targetScroll - currentScroll) * 0.08;
                if (!isRewindingHome && currentScroll < scrollLimitMin) {
                    currentScroll = scrollLimitMin;
                    targetScroll = scrollLimitMin;
                }
                scrollContainer.scrollLeft = currentScroll;
                if(parallaxBg) parallaxBg.style.transform = `translateX(${-currentScroll * 0.08}px)`;
                if (Math.abs(targetScroll - currentScroll) > 1) {
                    requestAnimationFrame(updateScroll);
                } else {
                    isAnimating = false;
                }
            };

            scrollContainer.addEventListener('wheel', (evt) => {
                if (!timelineActive) return;
                if (window.innerWidth >= 768 && !evt.shiftKey) {
                    evt.preventDefault();
                    const maxScroll = scrollContainer.scrollWidth - scrollContainer.clientWidth;
                    targetScroll += evt.deltaY * 1.5;
                    targetScroll = Math.max(0, Math.min(targetScroll, maxScroll));
                    
                    if (!isAnimating) {
                        isAnimating = true;
                        requestAnimationFrame(updateScroll);
                    }
                }
            }, { passive: false });

            // Ensure parallax updates seamlessly on native scroll as well
            scrollContainer.addEventListener('scroll', () => {
                if (!isRewindingHome && scrollContainer.scrollLeft < scrollLimitMin) {
                     scrollContainer.scrollLeft = scrollLimitMin;
                }
                if (!isAnimating) {
                     currentScroll = scrollContainer.scrollLeft;
                     targetScroll = currentScroll;
                }
                if (parallaxBg) {
                     parallaxBg.style.transform = `translateX(${-scrollContainer.scrollLeft * 0.08}px)`;
                }
            }, { passive: true });

            // Intercept Home Links for the Reverse Fly-out Transition to Unified Home
            document.querySelectorAll('a[href="/"]').forEach(link => {
                link.addEventListener('click', (e) => {
                    e.preventDefault();
                    
                    scrollContainer.style.pointerEvents = 'none';
                    isAnimating = true; // freeze normal wheel actions
                    isRewindingHome = true;
                    
                    if (floatingHeader) {
                        floatingHeader.classList.add('opacity-0');
                        floatingHeader.classList.remove('opacity-100');
                    }
                    if (exitContainer) {
                        exitContainer.classList.add('opacity-0', 'pointer-events-none');
                        exitContainer.classList.remove('opacity-100', 'pointer-events-auto');
                    }

                    const startScroll = scrollContainer.scrollLeft;
                    const duration = 2400; // Increased from 1200 to smoothen the rewind deceleration
                    const startTime = performance.now();
                    const easeOutQuint = (t) => 1 - Math.pow(1 - t, 5);

                    const swipeBack = (time) => {
                        let t = (time - startTime) / duration;
                        if (t > 1) t = 1;
                        
                        const easedS = startScroll * (1 - easeOutQuint(t));
                        scrollContainer.scrollLeft = easedS;
                        if(parallaxBg) parallaxBg.style.transform = `translateX(${-easedS * 0.08}px)`;

                        if (t < 1) {
                            requestAnimationFrame(swipeBack);
                        } else {
                            targetScroll = 0;
                            currentScroll = 0;
                            scrollLimitMin = 0;
                            timelineActive = false;
                            scrollContainer.style.pointerEvents = 'auto';
                            isAnimating = false;
                            isRewindingHome = false;
                            
                            const msg = document.getElementById('baby-hidden-message');
                            if (msg) {
                                msg.style.opacity = '0';
                                msg.style.transform = 'translateY(1.5rem) translateX(-50%)';
                            }
                        }
                    };
                    requestAnimationFrame(swipeBack);
                });
            });
        }

        // Cinematic Brain Zoom Logic
        const brainTrigger = document.getElementById('brain-link-trigger');
        if (brainTrigger) {
            brainTrigger.addEventListener('click', (e) => {
                e.preventDefault();
                
                const targetO = document.getElementById('zoom-target-o');
                const textContainer = document.getElementById('cinematic-koby-text');
                const kobyOnly = document.getElementById('cinematic-koby-only');
                const blackout = document.getElementById('blackout-overlay');
                
                if (targetO && textContainer && blackout && kobyOnly) {
                    sessionStorage.setItem('from_brain', 'true');

                    const oRect = targetO.getBoundingClientRect();
                    const kobyRect = kobyOnly.getBoundingClientRect();
                    // The bounding box of an inline-block includes font ascenders/descenders.
                    const visualCenterY = oRect.height * 0.65; 
                    const visualCenterX = (oRect.width / 2) + 4; // Shift 4px right

                    const originX = oRect.left - kobyRect.left + visualCenterX;
                    const originY = oRect.top - kobyRect.top + visualCenterY;
                    
                    const windowCenterX = window.innerWidth / 2;
                    const windowCenterY = window.innerHeight / 2;
                    const oScreenX = oRect.left + (oRect.width / 2);
                    const oScreenY = oRect.top + visualCenterY;
                    
                    const moveX = windowCenterX - oScreenX;
                    const moveY = windowCenterY - oScreenY;
                    
                    const heroSection = document.getElementById('unified-home-screen');
                    if (heroSection) heroSection.style.zIndex = '10000';
                    
                    kobyOnly.style.transformOrigin = `${originX}px ${originY}px`;
                    kobyOnly.style.willChange = 'transform';
                    kobyOnly.style.backfaceVisibility = 'hidden';
                    kobyOnly.style.position = 'relative';
                    kobyOnly.style.zIndex = '9999';
                    textContainer.style.zIndex = '9999';

                    requestAnimationFrame(() => {
                        // 1. Fade out everything except "Koby" first
                        document.querySelectorAll('a, p, nav, .cinematic-extra-text').forEach(el => {
                            if (el.style) {
                                el.style.transition = 'opacity 0.8s ease';
                                el.style.opacity = '0';
                            }
                        });
                        
                        // Fade blackout in immediately behind the text
                        blackout.style.transition = 'opacity 0.8s ease';
                        blackout.style.opacity = '1';
                        
                        // 1.5. Slide "Koby" to the center over 0.8s!
                        kobyOnly.style.transition = 'transform 0.8s ease-in-out';
                        kobyOnly.style.transform = `translate3d(${moveX}px, ${moveY}px, 0)`;
                        
                        // 2. Wait for fade & slide, PAUSE for 300ms, then start the zoom
                        setTimeout(() => {
                            // Extra slow start, ramp up heavily at the end
                            kobyOnly.style.transition = 'transform 2.5s cubic-bezier(0.8, 0, 0.9, 0.2)';
                            kobyOnly.style.transform = `translate3d(${moveX}px, ${moveY}px, 0) scale(100)`;

                            setTimeout(() => {
                                if (heroSection) heroSection.style.zIndex = '';
                                const link = document.createElement('a');
                                link.href = '/brain';
                                document.body.appendChild(link);
                                link.click();
                            }, 2400);
                        }, 1100);
                    });
                } else {
                    const link = document.createElement('a');
                    link.href = '/brain';
                    document.body.appendChild(link);
                    link.click();
                }
            });
        }

        // Reverse Animation logic when returning from /brain
        const fromBrain = sessionStorage.getItem('from_brain');
        const targetO = document.getElementById('zoom-target-o');
        const textContainer = document.getElementById('cinematic-koby-text');
        const kobyOnly = document.getElementById('cinematic-koby-only');
        const blackout = document.getElementById('blackout-overlay');
        const otherElements = document.querySelectorAll('a, p, nav, .cinematic-extra-text');
        
        if (fromBrain) {
            sessionStorage.removeItem('from_brain');
            
            // AGGRESSIVE BLACKOUT OVERRIDE: Prevent Astro fade glitch!
            if (blackout) {
                blackout.style.transition = 'none';
                blackout.style.opacity = '1';
                void blackout.offsetHeight;
            }
            
            if (targetO && textContainer && blackout && kobyOnly) {
                // FORCIBLY CLEAR Astro's cached inline styles BEFORE measuring!
                // If Astro restored the page from cache, textContainer might still be scaled from an old run!
                textContainer.style.transform = 'none';
                textContainer.style.transformOrigin = 'unset';
                
                kobyOnly.style.transition = 'none';
                kobyOnly.style.transform = 'none';
                kobyOnly.style.transformOrigin = 'unset';
                
                // Force synchronous layout recalculation
                void textContainer.offsetHeight;
                void kobyOnly.offsetHeight;
                
                const oRect = targetO.getBoundingClientRect();
                const kobyRect = kobyOnly.getBoundingClientRect();
                const heroSection = document.getElementById('unified-home-screen');
                
                if (heroSection) {
                    heroSection.style.zIndex = '10000'; // Escape stacking context!
                }
                
                const visualCenterY = oRect.height * 0.65;
                const visualCenterX = (oRect.width / 2) + 4; // Shift 4px right
                const originX = oRect.left - kobyRect.left + visualCenterX;
                const originY = oRect.top - kobyRect.top + visualCenterY;
                
                const windowCenterX = window.innerWidth / 2;
                const windowCenterY = window.innerHeight / 2;
                const oScreenX = oRect.left + visualCenterX;
                const oScreenY = oRect.top + visualCenterY;
                const moveX = windowCenterX - oScreenX;
                const moveY = windowCenterY - oScreenY;
                
                // --- ROBUST DEBUG LOGGING ---
                console.log('--- REVERSE TRANSITION INITIATED ---');
                let debugTick = 0;
                const debugInterval = setInterval(() => {
                    if (!kobyOnly) return;
                    const rect = kobyOnly.getBoundingClientRect();
                    const style = window.getComputedStyle(kobyOnly);
                    const heroStyle = heroSection ? window.getComputedStyle(heroSection) : null;
                    console.log(`[${debugTick}ms] kobyOnly | rect: ${rect.width.toFixed(1)}x${rect.height.toFixed(1)} at (${rect.x.toFixed(1)}, ${rect.y.toFixed(1)}) | op: ${style.opacity} | z: ${style.zIndex} | transform: ${style.transform !== 'none' ? 'active' : 'none'} | heroZ: ${heroStyle ? heroStyle.zIndex : 'N/A'}`);
                    debugTick += 100;
                }, 100);
                setTimeout(() => clearInterval(debugInterval), 3000);
                
                // --- TRICK CHROME: THE INVISIBLE PRE-SCALE ---
                kobyOnly.style.transformOrigin = `${originX}px ${originY}px`;
                kobyOnly.style.position = 'relative'; 
                kobyOnly.style.zIndex = '9999';
                
                // Start at 1x size, perfectly centered, virtually invisible
                kobyOnly.style.transform = `translate3d(${moveX}px, ${moveY}px, 0) scale(1)`;
                kobyOnly.style.opacity = '0.01';
                
                textContainer.style.zIndex = '9999';
                blackout.style.zIndex = '9990'; 
                blackout.style.opacity = '1';
                
                otherElements.forEach(el => {
                    if (el.style) {
                        el.style.opacity = '0';
                        el.style.transition = 'none';
                    }
                });

                void kobyOnly.offsetHeight; // Force layout

                requestAnimationFrame(() => {
                    // Rapidly stretch to 60x over 0.1s to force GPU texture caching
                    kobyOnly.style.transition = 'transform 0.1s linear';
                    kobyOnly.style.transform = `translate3d(${moveX}px, ${moveY}px, 0) scale(60)`;
                    
                    setTimeout(() => {
                        // The massive texture is now safely in GPU memory! Make it visible and shrink it!
                        kobyOnly.style.opacity = '1';
                        kobyOnly.style.transition = 'transform 2.5s cubic-bezier(0.1, 0.7, 0.4, 0.95)';
                        kobyOnly.style.transform = `translate3d(${moveX}px, ${moveY}px, 0) scale(1)`;
                        
                        // Wait for the 2.5s zoom to finish...
                        setTimeout(() => {
                            // Now slide it back to its original spot over 0.8s!
                            kobyOnly.style.transition = 'transform 0.8s ease-in-out';
                            kobyOnly.style.transform = 'translate3d(0px, 0px, 0) scale(1)';
                            
                            // DELAY the black overlay fade out and UI fade in until after the slide
                            setTimeout(() => {
                                if (blackout) {
                                    blackout.style.transition = 'opacity 1s ease-in-out';
                                    blackout.style.opacity = '0';
                                }
                                otherElements.forEach(el => {
                                    if (el.style) {
                                        el.style.transition = 'opacity 1s ease';
                                        el.style.opacity = '1';
                                    }
                                });
                            }, 800); // 800ms for slide to finish
                        }, 2500); // 2.5s for zoom to finish
                        
                        // Cleanup all inline styles so Tailwind hover states work again!
                        // Extended to 4500ms (2.5s zoom + 0.8s slide + 1.0s fade = 4.3s)
                        setTimeout(() => {
                            if (kobyOnly) {
                                kobyOnly.style.transform = '';
                                kobyOnly.style.transformOrigin = '';
                                kobyOnly.style.transition = '';
                                kobyOnly.style.position = '';
                                kobyOnly.style.zIndex = '';
                                kobyOnly.style.opacity = '';
                            }
                            if (textContainer) {
                                textContainer.style.zIndex = '';
                            }
                            if (blackout) {
                                blackout.style.transition = '';
                                blackout.style.zIndex = '';
                            }
                            if (heroSection) {
                                heroSection.style.zIndex = '';
                            }
                            otherElements.forEach(el => {
                                if (el.style) {
                                    el.style.transition = '';
                                    el.style.opacity = '';
                                }
                            });
                        }, 4500);
                    }, 150); // Wait 150ms for invisible stretch to finish
                });
            }
        } else {
            // NORMAL PAGE LOAD / NAVIGATION (not from Brain)
            // Wipe out any inline styles that Astro might have restored from the DOM cache!
            if (textContainer) {
                textContainer.style.transition = 'none';
                textContainer.style.transform = 'none';
                textContainer.style.transformOrigin = 'unset';
                textContainer.style.zIndex = '';
                
                // ULTIMATE REPAINT HACK for cached DOM
                textContainer.style.filter = 'blur(0.1px)';
                textContainer.style.textShadow = '0 0 1px rgba(0,0,0,0.01)';
                setTimeout(() => {
                    if(textContainer) {
                        textContainer.style.filter = '';
                        textContainer.style.textShadow = '';
                    }
                }, 50);
                
                // Let browser tick once before fully clearing transition so the snap is silent
                requestAnimationFrame(() => textContainer.style.transition = '');
            }
            if (blackout) {
                blackout.style.transition = 'none';
                blackout.style.opacity = '0';
                requestAnimationFrame(() => blackout.style.transition = '');
            }
            otherElements.forEach(el => {
                if (el.style) {
                    el.style.transition = 'none';
                    el.style.opacity = '';
                    requestAnimationFrame(() => el.style.transition = '');
                }
            });
        }
        });
    </script>
</body>
</html>

