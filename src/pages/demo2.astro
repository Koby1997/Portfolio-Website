---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Demo 2: Seamless Flow">
  <div class="max-w-7xl mx-auto py-12">
    <h1 class="text-3xl font-bold mb-4 px-8">Style 2: The Seamless Horizontal Line</h1>
    <p class="text-zinc-400 mb-8 px-8 max-w-4xl">Instead of separate cards, the timeline is one continuous physical trace. Content alternates above and below it on desktop.</p>
  </div>
  
  <div class="w-full md:overflow-x-auto pb-24 custom-scrollbar bg-zinc-950">
    <div class="flex flex-col md:flex-row items-center px-8 min-w-max relative py-12 md:py-32">
        <!-- Connecting Line (Desktop) -->
        <div class="hidden md:block absolute top-1/2 left-0 right-0 h-[2px] bg-zinc-800 -translate-y-1/2 z-0"></div>
        <div class="md:hidden absolute left-8 top-0 bottom-0 w-[2px] bg-zinc-800 z-0"></div> <!-- Mobile strict line -->

        <!-- Stop 1 (Bottom) -->
        <div class="relative w-full md:w-96 flex flex-col items-center md:items-start group md:mt-[15rem] px-4 mb-24 md:mb-0">
            <!-- Node Point -->
            <div class="w-5 h-5 rounded-full bg-emerald-500 absolute left-8 md:left-12 top-[-.5rem] md:top-[-15.75rem] -translate-x-1/2 md:-translate-x-0 group-hover:scale-150 transition-transform shadow-[0_0_15px_rgba(16,185,129,0.5)] z-10"></div>
            <!-- Connecting Stem -->
            <div class="md:absolute md:left-[3.5rem] md:top-[-15rem] w-0.5 h-16 md:h-64 bg-zinc-800 hidden md:block z-0"></div>
            
            <div class="text-left z-10 bg-zinc-950 p-2 relative pl-12 md:pl-0 pr-8">
                <span class="text-5xl font-black text-emerald-500 mb-4 block opacity-50">2022</span>
                <h3 class="text-2xl text-white mb-2 font-serif">Initial Testing</h3>
                <p class="text-zinc-400 text-sm leading-relaxed">Proof of concept logic mapping and early physical pressure tests. Many lessons learned the hard way.</p>
            </div>
        </div>

        <!-- Stop 2 (Top) -->
        <div class="relative w-full md:w-96 flex flex-col items-center md:items-start group md:-mt-[15rem] px-4 mb-24 md:mb-0">
            <!-- Node Point -->
            <div class="w-5 h-5 rounded-full bg-blue-500 absolute left-8 md:left-12 top-[-.5rem] md:bottom-[-15.75rem] md:top-auto -translate-x-1/2 md:-translate-x-0 group-hover:scale-150 transition-transform shadow-[0_0_15px_rgba(59,130,246,0.5)] z-10"></div>
            <!-- Connecting Stem -->
            <div class="md:absolute md:left-[3.5rem] md:bottom-[-15rem] w-0.5 h-16 md:h-64 bg-zinc-800 hidden md:block z-0"></div>
            
            <div class="text-left z-10 bg-zinc-950 p-2 relative pl-12 md:pl-0 pr-8">
                <span class="text-5xl font-black text-blue-500 mb-4 block opacity-50">2023</span>
                <h3 class="text-2xl text-white mb-2 font-serif">Structural Upgrade</h3>
                <p class="text-zinc-400 text-sm leading-relaxed">Moved to enterprise-grade materials. Completely redesigned the firing mechanism logic.</p>
            </div>
        </div>

        <!-- Stop 3 (Bottom) -->
        <div class="relative w-full md:w-96 flex flex-col items-center md:items-start group md:mt-[15rem] px-4 mb-24 md:mb-0">
            <!-- Node Point -->
            <div class="w-5 h-5 rounded-full bg-purple-500 absolute left-8 md:left-12 top-[-.5rem] md:top-[-15.75rem] -translate-x-1/2 md:-translate-x-0 group-hover:scale-150 transition-transform shadow-[0_0_15px_rgba(168,85,247,0.5)] z-10"></div>
            <!-- Connecting Stem -->
            <div class="md:absolute md:left-[3.5rem] md:top-[-15rem] w-0.5 h-16 md:h-64 bg-zinc-800 hidden md:block z-0"></div>
            
            <div class="text-left z-10 bg-zinc-950 p-2 relative pl-12 md:pl-0 pr-8">
                <span class="text-5xl font-black text-purple-500 mb-4 block opacity-50">2024</span>
                <h3 class="text-2xl text-white mb-2 font-serif">Perfect Execution</h3>
                <p class="text-zinc-400 text-sm leading-relaxed">Zero latency. Maximum velocity. The system operates flawlessly.</p>
            </div>
        </div>
        
    </div>
  </div>

  <script>
    const scrollContainer = document.querySelector('.custom-scrollbar');
    if (scrollContainer) {
      scrollContainer.addEventListener('wheel', (evt) => {
        if (window.innerWidth >= 768) {
          evt.preventDefault();
          scrollContainer.scrollLeft += evt.deltaY;
        }
      });
    }
  </script>
</Layout>
