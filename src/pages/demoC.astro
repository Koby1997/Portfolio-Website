---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Demo C | Ambient Flow">
  <div class="flex flex-col items-center justify-center min-h-[85vh] w-screen relative left-[calc(-50vw+50%)] overflow-hidden">
    
    <!-- Background Ambient Fluid Orbs -->
    <div class="absolute top-1/2 left-1/4 w-[50vw] h-[50vw] rounded-full bg-emerald-500/20 blur-[140px] -translate-y-1/2 animate-[spin_10s_linear_infinite] z-0"></div>
    <div class="absolute top-1/2 right-1/4 w-[45vw] h-[45vw] rounded-full bg-blue-500/20 blur-[120px] -translate-y-1/3 animate-[spin_12s_linear_infinite_reverse] z-0"></div>

    <div class="relative z-10 max-w-3xl text-center px-4">
        
        <div class="mb-8">
            <span class="px-4 py-1.5 rounded-full bg-white/5 border border-white/10 backdrop-blur-md text-white font-mono text-xs tracking-widest uppercase">
                Hardware + Software
            </span>
        </div>

        <h1 class="text-6xl md:text-8xl font-black text-white mb-8 drop-shadow-2xl mix-blend-overlay">
            Koby L.
        </h1>
        
        <p class="text-xl md:text-3xl text-zinc-300 font-light mb-16 drop-shadow-lg leading-relaxed mix-blend-overlay">
            Bridging the gap between tactile engineering and elegant digital experiences.
        </p>

        <a href="/projects" class="inline-flex items-center justify-center px-10 py-5 rounded-3xl bg-white/5 backdrop-blur-xl border border-white/10 hover:bg-white/10 transition-all shadow-2xl group cursor-pointer hover:scale-105 active:scale-95">
            <span class="text-white font-medium text-lg tracking-wide mr-6">Explore the Journey</span>
            <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center group-hover:translate-x-2 group-hover:bg-white/30 transition-all">
                <span class="text-white text-lg">&rarr;</span>
            </div>
        </a>
        
    </div>

  </div>
</Layout>
