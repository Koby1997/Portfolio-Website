---
import '../styles/global.css';

// Master Z-Space mapping. The user flies from Z:0 downwards to Z:-15000.
// We position hubs deep in Z-space. Children orbit them randomly.
const hubs = [
    {
        name: 'KINETICS',
        x: '20vw', y: '20vh', z: -2000,
        color: 'border-orange-500 shadow-[0_0_80px_rgba(249,115,22,0.4)]',
        children: ['Volleyball', 'Lacrosse', 'Rock Climbing', 'Paintball', 'Dodgeball', 'Traveling']
    },
    {
        name: 'TACTICAL ANALOG',
        x: '-20vw', y: '-30vh', z: -5500,
        color: 'border-purple-500 shadow-[0_0_80px_rgba(168,85,247,0.4)]',
        children: ['Magic the Gathering', 'Poker', 'Jigsaw Puzzles', 'Board Games', 'Escape Rooms']
    },
    {
        name: 'CINEMA',
        x: '30vw', y: '-10vh', z: -9000,
        color: 'border-blue-500 shadow-[0_0_80px_rgba(59,130,246,0.4)]',
        children: ['Tenet', 'Inception', 'Interstellar', 'Star Wars', 'Marvel']
    },
    {
        name: 'DIGITAL NARRATIVE',
        x: '-10vw', y: '30vh', z: -12500,
        color: 'border-emerald-500 shadow-[0_0_80px_rgba(16,185,129,0.4)]',
        children: ['Spider-Man', 'Ghost of Yōtei', 'God of War', 'The Last of Us']
    }
];

// Helper to generate a random spread around the Hub
function seededRandom(min, max) {
    return Math.random() * (max - min) + min;
}
---

<html lang="en" class="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>P.Space Flythrough</title>
    <style>
        .preserve-3d {
            transform-style: preserve-3d;
        }
        /* Hide scrollbars for cinematic effect but keep scroll functionality */
        ::-webkit-scrollbar {
            display: none;
        }
    </style>
</head>
<!-- The body is massively tall to give us physical scrollable space! -->
<body class="bg-[#050505] text-white m-0 p-0 font-sans h-[15000px] overflow-x-hidden">
    
    <!-- User Interface Overlay (Fixed to screen) -->
    <div class="fixed top-8 left-8 z-50 pointer-events-auto">
        <a href="/" class="text-white font-mono tracking-[0.2em] text-xs hover:text-rose-400 transition-colors uppercase pb-2 border-b border-white/20 hover:border-rose-400">
            &larr; Exit Universe
        </a>
    </div>

    <!-- HUD Indicators -->
    <div class="fixed top-1/2 left-8 -translate-y-1/2 z-50 pointer-events-none opacity-30">
        <div class="w-1 h-32 bg-zinc-800 rounded-full overflow-hidden">
            <div id="progress-bar" class="w-full h-0 bg-white shadow-[0_0_10px_white]"></div>
        </div>
    </div>
    
    <div class="fixed bottom-12 w-full text-center z-50 pointer-events-none">
        <p class="font-mono text-zinc-500 tracking-[0.4em] text-xs uppercase animate-pulse">Scroll to Fly Forward</p>
        <p id="z-coord" class="font-mono text-[10px] text-zinc-700 mt-2">Z: 0000</p>
    </div>

    <!-- The 3D Viewport. Fixed so it perfectly frames the screen. -->
    <div class="fixed inset-0 w-full h-full perspective-[1000px] overflow-hidden pointer-events-none">
        
        <!-- The Moving World (Z-Axis mapping based on scroll) -->
        <div id="world" class="absolute top-1/2 left-1/2 w-0 h-0 preserve-3d will-change-transform transform-gpu">
            
            {hubs.map(hub => {
                // The parent Hub Node
                return (
                    <div class="preserve-3d absolute" style={`transform: translate3d(${hub.x}, ${hub.y}, ${hub.z}px);`}>
                        
                        <!-- The Hub Title -->
                        <div class="absolute -translate-x-1/2 -translate-y-1/2 flex flex-col items-center justify-center">
                            <div class={`w-32 h-32 rounded-full border border-white/10 ${hub.color} bg-black/50 backdrop-blur-md flex items-center justify-center`}>
                                <div class="w-2 h-2 bg-white rounded-full"></div>
                            </div>
                            <h2 class="mt-8 text-4xl font-black tracking-[0.2em] text-white/80 drop-shadow-2xl text-center whitespace-nowrap">{hub.name}</h2>
                        </div>

                        <!-- The Child Satellites orbiting in local 3D space -->
                        {hub.children.map(child => {
                            // Spread children out around the hub
                            const offX = seededRandom(-600, 600);
                            const offY = seededRandom(-400, 400);
                            const offZ = seededRandom(-800, 800); // 3D depth of children!

                            return (
                                <div class={`absolute -translate-x-1/2 -translate-y-1/2 flex items-center pointer-events-auto cursor-pointer hover:scale-125 transition-transform duration-300 group`} 
                                     style={`transform: translate3d(${offX}px, ${offY}px, ${offZ}px);`}>
                                    
                                    <div class="w-1.5 h-1.5 bg-zinc-500 rounded-full group-hover:bg-white group-hover:shadow-[0_0_10px_white] transition-all"></div>
                                    <span class="ml-4 font-mono text-xs tracking-widest text-zinc-500/80 group-hover:text-white uppercase whitespace-nowrap drop-shadow bg-black/50 px-3 py-1 rounded backdrop-blur">
                                        {child}
                                    </span>
                                </div>
                            )
                        })}

                    </div>
                )
            })}

        </div>

        <!-- Ambient Space Dust -->
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_0%,#000_100%)]"></div>
    </div>

    <script is:inline>
        const world = document.getElementById('world');
        const progressBar = document.getElementById('progress-bar');
        const zCoord = document.getElementById('z-coord');
        const maxScroll = document.body.scrollHeight - window.innerHeight;

        function update3D() {
            // raw scroll pixel value
            const scrollY = window.scrollY;
            
            // Move the world TOWARDS the camera (positive Z)
            world.style.transform = `translate3d(0, 0, ${scrollY}px)`;
            
            // UX updates
            zCoord.innerText = `DEPTH: ${Math.floor(scrollY)}`;
            progressBar.style.height = `${(scrollY / maxScroll) * 100}%`;
        }

        // Bind efficiently
        window.addEventListener('scroll', () => {
            requestAnimationFrame(update3D);
        });

        // Initialize
        update3D();
    </script>
</body>
</html>
