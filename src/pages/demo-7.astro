---
import '../styles/global.css';
---
<!doctype html>
<html lang="en" class="dark scroll-smooth">
<head><meta charset="UTF-8" /><title>Demo 7 - Tri-Node Gateway</title></head>
<body class="bg-zinc-950 text-zinc-50 flex flex-col items-center justify-center min-h-screen overflow-hidden m-0 p-0 relative">
  
  <!-- Complex Background -->
  <div class="absolute inset-0 z-0">
     <!-- Glowing spots -->
     <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-blue-600/20 rounded-full blur-[100px] mix-blend-screen pointer-events-none"></div>
     <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-emerald-600/10 rounded-full blur-[100px] mix-blend-screen pointer-events-none"></div>
     <!-- Subtle grid -->
     <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none"></div>
  </div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-12 flex flex-col pt-12 pb-20">
    <!-- Intro Text Area -->
    <div class="max-w-3xl mb-16">
      <div class="inline-block px-4 py-1.5 rounded-full border border-blue-500/30 bg-blue-500/10 text-blue-400 font-mono text-xs tracking-[0.2em] mb-6">
        PORTFOLIO SYSTEM
      </div>
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight leading-tight">
        Hi, I'm Koby. <br/>
        <span class="text-zinc-500">I engineer dynamic hardware and immersive software.</span>
      </h1>
      <p class="text-xl md:text-2xl text-zinc-400 font-light leading-relaxed">
        This isn't a standard website. It's a spatial experience. Choose a sector below to interact with my work.
      </p>
    </div>

    <!-- The 3 Navigation Gateways -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-10">
      
      <!-- Box 1: Timeline -->
      <a href="#" class="group relative p-1 rounded-2xl bg-gradient-to-b from-zinc-800 to-zinc-900 border border-zinc-800/50 overflow-hidden hover:border-blue-500/50 transition-all duration-500 cursor-pointer">
         <div class="absolute inset-0 bg-blue-500/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
         <div class="relative h-full bg-zinc-950/80 backdrop-blur-xl rounded-xl p-8 flex flex-col justify-between">
           <div>
             <div class="w-12 h-12 rounded-full border border-zinc-700 bg-zinc-900 flex items-center justify-center mb-6 group-hover:scale-110 group-hover:border-blue-500 transition-all">
                <svg class="w-5 h-5 text-zinc-400 group-hover:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
             </div>
             <h3 class="text-2xl font-bold text-white mb-3">The Timeline</h3>
             <p class="text-zinc-400 font-light leading-relaxed">A chronological journey through my past projects, experiences, and history.</p>
           </div>
           
           <div class="mt-12 flex items-center gap-3 text-sm font-mono tracking-widest text-zinc-500 group-hover:text-white transition-colors">
             SWIPE LEFT <span class="group-hover:translate-x-2 transition-transform text-lg">→</span>
           </div>
         </div>
      </a>

      <!-- Box 2: Brain -->
      <a href="/brain" class="group relative p-1 rounded-2xl bg-gradient-to-b from-blue-900/40 to-zinc-900 border border-blue-500/30 overflow-hidden hover:border-blue-400 transition-all duration-500 md:-translate-y-6 shadow-[0_0_30px_rgba(59,130,246,0.15)] hover:shadow-[0_0_50px_rgba(59,130,246,0.25)] cursor-pointer">
         <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(59,130,246,0.2)_0%,transparent_70%)]"></div>
         <div class="relative h-full bg-zinc-950/60 backdrop-blur-md rounded-xl p-8 flex flex-col justify-between border-t border-blue-400/20">
           <div>
             <div class="w-12 h-12 rounded-full border border-blue-500/50 bg-blue-900/30 flex items-center justify-center mb-6 shadow-[0_0_15px_rgba(59,130,246,0.4)] group-hover:scale-110 transition-all">
                <svg class="w-5 h-5 text-blue-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
             </div>
             <h3 class="text-2xl font-bold text-white mb-3">The Neural Core</h3>
             <p class="text-zinc-300 font-light leading-relaxed">Dive deep into my interactive 3D mindset. See how my hobbies and engineering principles explicitly connect.</p>
           </div>
           
           <div class="mt-12 flex items-center gap-3 text-sm font-mono tracking-widest text-blue-400 group-hover:text-blue-300 transition-colors">
             <span class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></span>
             INITIATE ZOOM
           </div>
         </div>
      </a>

      <!-- Box 3: Resume -->
      <a href="/resume" class="group relative p-1 rounded-2xl bg-gradient-to-b from-zinc-800 to-zinc-900 border border-zinc-800/50 overflow-hidden hover:border-emerald-500/50 transition-all duration-500 cursor-pointer">
         <div class="absolute inset-0 bg-emerald-500/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
         <div class="relative h-full bg-zinc-950/80 backdrop-blur-xl rounded-xl p-8 flex flex-col justify-between">
           <div>
             <div class="w-12 h-12 rounded-full border border-zinc-700 bg-zinc-900 flex items-center justify-center mb-6 group-hover:scale-110 group-hover:border-emerald-500 transition-all">
                <svg class="w-5 h-5 text-zinc-400 group-hover:text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
             </div>
             <h3 class="text-2xl font-bold text-white mb-3">The Credentials</h3>
             <p class="text-zinc-400 font-light leading-relaxed">The professional breakdown. Logic toggles, stack breakdowns, and official resume downloads.</p>
           </div>
           
           <div class="mt-12 flex items-center gap-3 text-sm font-mono tracking-widest text-zinc-500 group-hover:text-white transition-colors">
             SWIPE UP <span class="group-hover:-translate-y-1 transition-transform text-lg">↑</span>
           </div>
         </div>
      </a>

    </div>
  </div>
  
  <div class="absolute top-8 right-8 z-50">
    <a href="/" class="text-zinc-500 hover:text-white px-4 py-2 border border-zinc-800 rounded-lg bg-zinc-900 hover:bg-zinc-800 transition">Return to Home</a>
  </div>
</body>
</html>
