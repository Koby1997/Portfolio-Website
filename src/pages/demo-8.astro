---
import '../styles/global.css';
---
<!doctype html>
<html lang="en" class="dark scroll-smooth">
<head><meta charset="UTF-8" /><title>Demo 8 - Spatial HUD</title></head>
<body class="bg-zinc-950 text-zinc-50 flex items-center justify-center h-screen overflow-hidden m-0 p-0 relative selection:bg-blue-500/30">

  <!-- Background Layer -->
  <div class="absolute inset-0 z-0 bg-[radial-gradient(ellipse_at_center,rgba(59,130,246,0.06)_0%,transparent_60%)] pointer-events-none"></div>

  <!-- Center Content (Brain & Intro) -->
  <div class="relative z-10 max-w-4xl px-8 flex flex-col items-center text-center">
    <div class="mb-8 w-16 h-1 bg-gradient-to-r from-blue-600 to-emerald-400"></div>
    <h1 class="text-6xl md:text-8xl font-bold tracking-tight text-white mb-6">
      Hi, I'm Koby.
    </h1>
    <p class="text-2xl text-zinc-300 font-light max-w-3xl leading-relaxed mb-12">
      I engineer robust software and craft dynamic hardware experiences. 
      This is a spatial portfolio designed to be explored.
    </p>

    <!-- The Primary Button (Brain) -->
    <a href="/brain" class="group relative px-10 py-5 bg-zinc-900/80 backdrop-blur-xl border border-blue-500/40 hover:border-blue-400 rounded-2xl overflow-hidden transition-all duration-300 shadow-[0_0_20px_rgba(59,130,246,0.15)] hover:shadow-[0_0_40px_rgba(59,130,246,0.3)] hover:-translate-y-1">
       <div class="absolute inset-0 bg-blue-500/10 group-hover:bg-blue-500/20 transition-colors"></div>
       <div class="relative flex items-center gap-4">
          <div class="w-3 h-3 rounded-full bg-blue-400 animate-pulse shadow-[0_0_10px_#60a5fa] group-hover:bg-blue-300"></div>
          <span class="text-white font-mono tracking-[0.2em] text-sm md:text-base font-bold uppercase">Enter The Neural Core</span>
       </div>
    </a>
  </div>

  <!-- Edge Anchor: TIMELINE (Right Side) -->
  <a href="#" class="absolute right-0 top-1/2 -translate-y-1/2 group h-96 w-16 sm:w-24 flex items-center justify-center border-l flex-col pt-12 border-zinc-800/50 bg-gradient-to-l from-zinc-900/80 to-transparent hover:bg-zinc-800/60 hover:w-32 transition-all duration-500 border-r-4 border-r-transparent hover:border-r-blue-500 cursor-pointer backdrop-blur-sm">
    <span class="[writing-mode:vertical-rl] rotate-180 text-zinc-500 group-hover:text-white font-mono tracking-[0.4em] uppercase text-xs mb-8 transition-colors">
      Timeline
    </span>
    <svg class="w-8 h-8 text-zinc-600 group-hover:text-blue-400 transition-colors opacity-50 group-hover:opacity-100 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7" /></svg>
  </a>

  <!-- Edge Anchor: RESUME (Bottom Side) -->
  <a href="/resume" class="absolute bottom-0 left-1/2 -translate-x-1/2 group w-96 h-20 sm:h-24 flex flex-col items-center justify-center border-t border-zinc-800/50 bg-gradient-to-t from-zinc-900/80 to-transparent hover:bg-zinc-800/60 hover:h-32 transition-all duration-500 border-b-4 border-b-transparent hover:border-b-emerald-500 cursor-pointer backdrop-blur-sm">
    <svg class="w-6 h-6 text-zinc-600 group-hover:text-emerald-400 transition-colors mb-3 opacity-50 group-hover:opacity-100 group-hover:-translate-y-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" /></svg>
    <span class="text-zinc-500 group-hover:text-white font-mono tracking-[0.4em] uppercase text-xs transition-colors">
      Resume / Credentials
    </span>
  </a>

  <!-- Simple exit anchor -->
  <div class="absolute top-8 left-8 z-50">
    <a href="/" class="text-zinc-600 hover:text-white flex items-center gap-2 group transition">
      <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <span class="font-mono tracking-widest text-xs uppercase">Back</span>
    </a>
  </div>

</body>
</html>
