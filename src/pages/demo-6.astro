---
import '../styles/global.css';
---
<!doctype html>
<html lang="en" class="dark scroll-smooth">
<head><meta charset="UTF-8" /><title>Demo 6 - The Growing Node</title></head>
<body class="bg-zinc-950 text-zinc-50 flex flex-col items-center justify-center h-screen overflow-hidden m-0 p-0">
  
  <div class="relative z-10 flex flex-col items-center">
    <!-- Directional Cue -->
    <div class="mb-8 flex flex-col items-center opacity-60">
      <div class="w-[2px] h-24 bg-gradient-to-b from-transparent to-emerald-500 mb-6 animate-pulse"></div>
      <p class="text-xs text-emerald-400 font-mono tracking-[0.3em] uppercase text-center w-64">
        Incoming Connection
      </p>
    </div>
    
    <h1 class="text-7xl sm:text-[9rem] font-bold tracking-tighter text-white flex items-center mb-10">
      K<span class="relative mx-3 cursor-pointer group flex items-center justify-center">
        <span class="transition-opacity group-hover:opacity-0 relative z-10">o</span>
        <span class="absolute w-2 h-2 bg-emerald-500 rounded-full"></span>
        
        <!-- The Node replacing 'o' on hover -->
        <span class="absolute w-2 h-2 bg-emerald-500 rounded-full shadow-[0_0_30px_#10b981] group-hover:w-20 group-hover:h-20 sm:group-hover:w-28 sm:group-hover:h-28 group-hover:bg-emerald-500/20 group-hover:backdrop-blur-md transition-all duration-300 flex flex-col items-center justify-center border border-emerald-400/50">
           <span class="opacity-0 group-hover:opacity-100 text-white text-[10px] sm:text-xs tracking-widest font-mono uppercase transition-opacity delay-150">Zoom In</span>
        </span>
      </span>by.
    </h1>
    
    <p class="text-zinc-500 text-xl font-light tracking-wide text-center">
       Click the central node to transition to the Brain.
    </p>
  </div>

  <div class="absolute bottom-8 right-8 z-50">
    <a href="/" class="text-zinc-500 hover:text-white px-4 py-2 border border-zinc-800 rounded-lg bg-zinc-900 hover:bg-zinc-800 transition">Return to Home</a>
  </div>
</body>
</html>
