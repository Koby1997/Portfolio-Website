---
import '../styles/global.css';

const orbits = [
    { 
        size: 300, speed: 60, color: 'border-emerald-500/30', glow: 'shadow-[0_0_50px_rgba(16,185,129,0.1)]',
        items: [
            { name: 'Magic the Gathering', color: 'text-emerald-400' }, 
            { name: 'Poker', color: 'text-emerald-400' }, 
            { name: 'Puzzle Solving', color: 'text-emerald-400' }
        ] 
    },
    { 
        size: 550, speed: 80, color: 'border-orange-500/30', glow: 'shadow-[0_0_80px_rgba(249,115,22,0.1)]',
        items: [
            { name: 'Volleyball', color: 'text-orange-400' }, 
            { name: 'Lacrosse', color: 'text-orange-400' }, 
            { name: 'Rock Climbing', color: 'text-orange-400' },
            { name: 'Dodgeball', color: 'text-orange-400' },
            { name: 'Paintball', color: 'text-orange-400' }
        ] 
    },
    { 
        size: 800, speed: 120, color: 'border-blue-500/30', glow: 'shadow-[0_0_120px_rgba(59,130,246,0.1)]',
        items: [
            { name: 'Tenet', color: 'text-blue-400' }, 
            { name: 'Interstellar', color: 'text-blue-400' }, 
            { name: 'Spider-Man', color: 'text-blue-400' },
            { name: 'God of War', color: 'text-blue-400' },
            { name: 'The Last of Us', color: 'text-blue-400' },
            { name: 'Star Wars', color: 'text-blue-400' }
        ] 
    }
];

---
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>P5. Orchestral Orbits</title>
</head>
<body class="bg-zinc-950 text-white overflow-hidden w-screen h-screen m-0 p-0 font-sans flex items-center justify-center">

    <div class="fixed top-8 left-8 z-50">
        <a href="/" class="text-white font-mono tracking-[0.2em] text-xs hover:text-white/50 uppercase pb-2 border-b border-white/20">&larr; Matrix</a>
    </div>

    <!-- The Star System -->
    <div class="relative w-0 h-0 flex items-center justify-center scale-50 sm:scale-75 md:scale-100">
        
        <!-- The Core -->
        <div class="absolute w-32 h-32 bg-white rounded-full z-10 shadow-[0_0_100px_rgba(255,255,255,0.8)] flex items-center justify-center">
            <span class="text-black font-black text-2xl tracking-tighter">KOBY L.</span>
        </div>

        {orbits.map((orbit) => (
            <!-- Orbit Ring rotates normally -->
            <div 
                class={`absolute rounded-full border-2 border-dashed ${orbit.color} ${orbit.glow} flex items-center justify-center`}
                style={`width: ${orbit.size}px; height: ${orbit.size}px; animation: spin-right ${orbit.speed}s linear infinite;`}
            >
                {orbit.items.map((item, index) => {
                    // Distribute items evenly along the ring mathematically
                    const angle = (index * 360) / orbit.items.length;
                    
                    return (
                        // Wrapper to place it at the edge of the ring
                        <div class="absolute w-full h-full flex justify-center pointer-events-none" style={`transform: rotate(${angle}deg);`}>
                            
                            <!-- The actual item is placed at the top of the bounded wrapper, then rotates backwards to stay upright! -->
                            <div class="absolute pointer-events-auto cursor-pointer hover:scale-125 transition-transform" style={`top: -24px; animation: spin-left ${orbit.speed}s linear infinite;`}>
                                <div class="bg-zinc-950 px-6 py-3 border border-white/10 rounded-full backdrop-blur-xl shadow-2xl flex items-center whitespace-nowrap">
                                    <div class={`w-3 h-3 rounded-full bg-current ${item.color} mr-3 shadow-[0_0_15px_currentColor]`}></div>
                                    <span class="font-bold tracking-tight text-white">{item.name}</span>
                                </div>
                            </div>
                        </div>
                    )
                })}
            </div>
        ))}

    </div>

    <style>
        @keyframes spin-right { 100% { transform: rotate(360deg); } }
        /* To keep items upright while their parent spins right, they must spin left at the exact same rate! */
        @keyframes spin-left { 100% { transform: rotate(-360deg); } }
        
        /* Pause on hover by pausing both animations */
        div:hover > div[style*="spin-right"],
        div:hover > div > div > div[style*="spin-left"] {
            animation-play-state: paused !important;
        }
    </style>
</body>
</html>
