---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<Layout title="Projects | Koby L.">
  <div class="max-w-5xl mx-auto py-12">
    <h1 class="text-4xl font-bold mb-4">My Work</h1>
    <p class="text-zinc-400 mb-10 text-lg">A collection of custom software, hardware builds, and engineering challenges.</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <a href={`/projects/${project.id}`} class="group block h-full">
          <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6 h-full hover:border-zinc-500 transition-all hover:bg-zinc-800/50 flex flex-col">
            <div class="flex justify-between items-start mb-4">
              <span class="px-3 py-1 bg-zinc-800 text-xs font-semibold text-zinc-300 rounded-full">{project.data.category}</span>
            </div>
            <h2 class="text-xl font-bold text-white mb-2 group-hover:text-blue-400 transition-colors">{project.data.title}</h2>
            <p class="text-zinc-400 flex-grow text-sm">{project.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
