---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const getColorConfig = (category) => {
   switch(category.toLowerCase()) {
       case 'software': return { text: 'text-emerald-500', bg: 'bg-emerald-500/10' };
       case 'hardware': return { text: 'text-blue-500', bg: 'bg-blue-500/10' };
       case 'event': return { text: 'text-orange-500', bg: 'bg-orange-500/10' };
       case 'engineering': return { text: 'text-cyan-500', bg: 'bg-cyan-500/10' };
       case 'milestone': return { text: 'text-purple-500', bg: 'bg-purple-500/10' };
       default: return { text: 'text-zinc-400', bg: 'bg-zinc-800/10' };
   }
}
const primaryCategory = project.data.categories[0] || 'Unknown';
const colors = getColorConfig(primaryCategory);

let galleryFiles = [];
if (project.data.mediaFolder) {
    const publicPath = path.join(process.cwd(), 'public', project.data.mediaFolder);
    try {
        if (fs.existsSync(publicPath)) {
            const files = fs.readdirSync(publicPath);
            galleryFiles = files.filter(f => /\.(jpg|jpeg|png|gif|mp4|webm|mov)$/i.test(f)).map(f => {
                return `${project.data.mediaFolder}/${f}`;
            });
        }
    } catch (e) {
        console.error("Error reading media folder", e);
    }
}

if (project.data.coverImage) {
    galleryFiles = galleryFiles.filter(f => f !== project.data.coverImage);
}

if (project.body) {
    // Exclude any files that the user has explicitly placed in the markdown content
    galleryFiles = galleryFiles.filter(f => !project.body.includes(path.basename(f)));
}

const images = galleryFiles.filter(f => /\.(jpg|jpeg|png|gif)$/i.test(f));
const videos = galleryFiles.filter(f => /\.(mp4|webm|mov)$/i.test(f));
---
<Layout title={`${project.data.title} | Koby L.`} hideNavAndFooter={true}>
  <div class="w-full bg-zinc-950 text-white min-h-[100dvh]">
    
    <!-- Floating Back Button -->
    <button onclick="window.history.back()" class="group fixed top-8 left-8 flex items-center justify-center w-12 h-12 bg-black/50 backdrop-blur-md border border-white/10 rounded-full hover:bg-black/80 hover:-translate-x-1 transition-all shadow-xl z-50 cursor-pointer">
        <span class="text-zinc-300 group-hover:text-white">&larr;</span>
    </button>

    <!-- Massive Hero - Edge to Edge with Magic Zoom Tie -->
    <div 
        transition:name={`project-box-${project.id}`}
        class="w-full h-[60vh] md:h-[80vh] relative overflow-hidden bg-zinc-900"
    >
        {project.data.coverImage ? (
            project.data.heroFit === 'contain' ? (
                <>
                    {/\.(mp4|webm|mov)$/i.test(project.data.coverImage) ? (
                        <>
                            <video src={project.data.coverImage} autoplay loop muted playsinline class="absolute inset-0 w-full h-full object-cover z-0 opacity-40 blur-3xl scale-110"></video>
                            <video src={project.data.coverImage} autoplay loop muted playsinline class="w-full h-full object-contain z-10 relative drop-shadow-2xl"></video>
                        </>
                    ) : (
                        <>
                            <img src={project.data.coverImage} class="absolute inset-0 w-full h-full object-cover z-0 opacity-40 blur-3xl scale-110" />
                            <img src={project.data.coverImage} class="w-full h-full object-contain z-10 relative drop-shadow-2xl" />
                        </>
                    )}
                </>
            ) : (
                /\.(mp4|webm|mov)$/i.test(project.data.coverImage) ? (
                    <video 
                        src={project.data.coverImage} 
                        autoplay loop muted playsinline 
                        class="w-full h-full object-cover z-0 opacity-100" 
                    ></video>
                ) : (
                    <img 
                        src={project.data.coverImage} 
                        class="w-full h-full object-cover z-0 opacity-100" 
                    />
                )
            )
        ) : (
            <div class="w-full h-full bg-zinc-900 flex items-center justify-center font-mono text-zinc-600 text-3xl">
                [ {primaryCategory.toUpperCase()} HERO ]
            </div>
        )}
        
        <div class="absolute inset-0 flex flex-col justify-end p-8 md:p-16">
            <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/40 to-transparent z-10 h-full pointer-events-none"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-zinc-950 via-zinc-950/20 to-transparent z-10 w-[80vw] pointer-events-none"></div>

            <div class="relative z-20 max-w-4xl pt-24">
                <div class="flex flex-wrap gap-2 mb-6">
                    {project.data.categories.map((cat) => {
                        const subColors = getColorConfig(cat);
                        return <span class={`px-4 py-1.5 ${subColors.bg} border border-current/20 ${subColors.text} text-[10px] font-bold tracking-widest uppercase rounded backdrop-blur-sm`}>{cat}</span>
                    })}
                </div>
                
                <h1 class="text-6xl md:text-8xl xl:text-[10rem] font-black tracking-tighter mb-4 text-white leading-[0.9] drop-shadow-2xl inline-block whitespace-nowrap">
                    {project.data.title}
                </h1>
                
                <p class="text-xl md:text-2xl text-zinc-300 drop-shadow-xl font-light mt-4 max-w-2xl leading-relaxed">
                    {project.data.description}
                </p>
            </div>
        </div>
    </div>

    <!-- CONTENT PAYLOAD -->
    {project.data.demoMode ? (
        <div class="w-full">
            <Content />
        </div>
    ) : (
        <>
            <!-- Section 1: Dynamic Markdown Payload (Sticky Left, Content Right) -->
            <div class="w-full px-4 md:px-16 py-16 flex flex-col xl:flex-row gap-16 border-b border-zinc-800">
                
                <div class="xl:w-1/3 xl:sticky xl:top-32 h-fit mb-8 xl:mb-0">
                    <h2 class="text-3xl font-bold mb-6">Project Context</h2>
                    
                    <div class="flex flex-col gap-4 border-l-2 border-zinc-800 pl-6">
                        <div>
                            <span class="text-zinc-500 font-mono text-xs uppercase tracking-widest block mb-1">Timeframe</span>
                            <span class="text-white text-lg font-medium">{project.data.pubDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</span>
                        </div>
                        <div>
                            <span class="text-zinc-500 font-mono text-xs uppercase tracking-widest block mb-1">Primary Discipline</span>
                            <span class="text-white text-lg font-medium">{primaryCategory}</span>
                        </div>
                    </div>
                </div>
        
        <div class="xl:w-2/3 prose prose-invert prose-lg max-w-none prose-headings:font-bold prose-a:text-blue-400 hover:prose-a:text-blue-300 prose-img:rounded-3xl prose-img:w-full prose-img:h-auto prose-img:shadow-2xl">
            <Content />
        </div>

    </div>

    {galleryFiles.length > 0 && (
        <div class="w-full px-4 md:px-16 py-24 flex flex-col xl:flex-row gap-16 border-t border-zinc-800">
            <div class="xl:w-1/3 xl:sticky xl:top-32 h-fit mb-12 xl:mb-0">
                <h2 class="text-3xl font-bold mb-6">Project Media</h2>
                <p class="text-xl text-zinc-400 leading-relaxed mb-6">Visual documentation and process capture for this build.</p>
            </div>
            
            <div class="xl:w-2/3 flex flex-col gap-12">
                {videos.length > 0 && videos.map(vid => (
                    <video src={vid} autoplay loop muted playsinline class="w-full h-auto rounded-3xl border border-zinc-800 shadow-2xl"></video>
                ))}
                
                {images.length > 0 && (
                    <div class="columns-1 md:columns-2 gap-8 space-y-8">
                        {images.map(img => (
                            <img src={img} loading="lazy" class="w-full h-auto object-cover rounded-3xl border border-zinc-800 shadow-xl break-inside-avoid hover:scale-[1.02] transition-transform duration-300" />
                        ))}
                    </div>
                )}
            </div>
        </div>
    )}
    </>
    )}

  </div>

    <!-- Lightbox Overlay -->
    <div id="lightbox-overlay" class="fixed inset-0 z-[100] bg-black/95 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-300 flex items-center justify-center p-4 md:p-12">
        <button id="lightbox-close" class="absolute top-8 right-8 text-white/50 hover:text-white z-50 p-4 cursor-pointer">
            <svg class="w-10 h-10 drop-shadow-lg" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
        <div id="lightbox-content" class="relative w-full h-full flex items-center justify-center max-w-7xl mx-auto transform scale-95 transition-transform duration-300">
        </div>
    </div>

<script>
    document.addEventListener('astro:page-load', () => {
        const overlay = document.getElementById('lightbox-overlay');
        const contentContainer = document.getElementById('lightbox-content');
        const closeBtn = document.getElementById('lightbox-close');
        
        if (!overlay || !contentContainer || !closeBtn) return;

        const mediaElements = document.querySelectorAll('img, video');
        
        const closeLightbox = () => {
            overlay.classList.remove('opacity-100', 'pointer-events-auto');
            overlay.classList.add('opacity-0', 'pointer-events-none');
            contentContainer.classList.remove('scale-100');
            contentContainer.classList.add('scale-95');
            setTimeout(() => {
                contentContainer.innerHTML = '';
            }, 300);
        };

        overlay.addEventListener('click', (e) => {
            if (e.target === overlay || e.target === contentContainer) {
                closeLightbox();
            }
        });
        closeBtn.addEventListener('click', closeLightbox);
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeLightbox();
        });

        mediaElements.forEach(el => {
            if (el.closest('a')) return;
            if (el.closest('.h-\\[60vh\\]') || el.closest('.h-\\[80vh\\]')) return;

            el.classList.add('cursor-zoom-in');
            
            el.addEventListener('click', () => {
                const isVideo = el.tagName.toLowerCase() === 'video';
                const src = el.getAttribute('src');
                
                contentContainer.innerHTML = '';
                
                if (isVideo) {
                    const vid = document.createElement('video');
                    vid.src = src;
                    vid.controls = true;
                    vid.autoplay = true;
                    vid.className = 'max-w-full max-h-[90vh] rounded-2xl shadow-2xl object-contain border border-zinc-800';
                    contentContainer.appendChild(vid);
                } else {
                    const img = document.createElement('img');
                    img.src = src;
                    img.className = 'max-w-full max-h-[90vh] rounded-2xl shadow-2xl object-contain border border-zinc-800';
                    contentContainer.appendChild(img);
                }

                overlay.classList.remove('opacity-0', 'pointer-events-none');
                overlay.classList.add('opacity-100', 'pointer-events-auto');
                contentContainer.classList.remove('scale-95');
                contentContainer.classList.add('scale-100');
            });
        });
    });
</script>
</Layout>
