---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const getColorConfig = (category) => {
   switch(category.toLowerCase()) {
       case 'software': return { text: 'text-emerald-500', bg: 'bg-emerald-500/10' };
       case 'hardware': return { text: 'text-blue-500', bg: 'bg-blue-500/10' };
       case 'event': return { text: 'text-orange-500', bg: 'bg-orange-500/10' };
       case 'engineering': return { text: 'text-cyan-500', bg: 'bg-cyan-500/10' };
       case 'milestone': return { text: 'text-purple-500', bg: 'bg-purple-500/10' };
       default: return { text: 'text-zinc-400', bg: 'bg-zinc-800/10' };
   }
}
const primaryCategory = project.data.categories[0] || 'Unknown';
const colors = getColorConfig(primaryCategory);

// For the demo request, we will hardcode the proposal images IF the project ID is proposal.
// Otherwise we just show a generic placeholder. In the future this will be data driven!
const isProposal = project.id === 'proposal';
---
<Layout title={`${project.data.title} | Koby L.`}>
  <div class="w-screen relative left-[calc(-50vw+50%)] bg-zinc-950 text-white min-h-[100dvh]">
    
    <!-- Floating Back Button -->
    <button onclick="window.history.back()" class="group fixed top-8 left-8 flex items-center justify-center w-12 h-12 bg-black/50 backdrop-blur-md border border-white/10 rounded-full hover:bg-black/80 hover:-translate-x-1 transition-all shadow-xl z-50 cursor-pointer">
        <span class="text-zinc-300 group-hover:text-white">&larr;</span>
    </button>

    <!-- Massive Hero - Edge to Edge with Magic Zoom Tie -->
    <div 
        transition:name={`project-box-${project.id}`}
        class="w-full h-[60vh] md:h-[80vh] relative overflow-hidden bg-zinc-900 border-b border-zinc-800"
    >
        {project.data.coverImage ? (
            <img 
                src={project.data.coverImage} 
                class="w-full h-full object-cover z-0 opacity-100" 
            />
        ) : (
            <div class="w-full h-full bg-zinc-900 flex items-center justify-center font-mono text-zinc-600 text-3xl">
                [ {primaryCategory.toUpperCase()} HERO ]
            </div>
        )}
        
        <div class="absolute inset-0 flex flex-col justify-end p-8 md:p-16">
            <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/40 to-transparent z-10 h-full pointer-events-none"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-zinc-950 via-zinc-950/20 to-transparent z-10 w-[80vw] pointer-events-none"></div>

            <div class="relative z-20 max-w-4xl pt-24">
                <div class="flex flex-wrap gap-2 mb-6">
                    {project.data.categories.map((cat) => {
                        const subColors = getColorConfig(cat);
                        return <span class={`px-4 py-1.5 ${subColors.bg} border border-current/20 ${subColors.text} text-[10px] font-bold tracking-widest uppercase rounded backdrop-blur-sm`}>{cat}</span>
                    })}
                </div>
                
                <h1 class="text-6xl md:text-8xl xl:text-[10rem] font-black tracking-tighter mb-4 text-white leading-[0.9] drop-shadow-2xl inline-block whitespace-nowrap">
                    {project.data.title}
                </h1>
                
                <p class="text-xl md:text-2xl text-zinc-300 drop-shadow-xl font-light mt-4 max-w-2xl leading-relaxed">
                    {project.data.description}
                </p>
            </div>
        </div>
    </div>

    <!-- Section 1: Dynamic Markdown Payload (Sticky Left, Content Right) -->
    <div class="w-full px-4 md:px-16 py-16 flex flex-col xl:flex-row gap-16 border-b border-zinc-800">
        
        <div class="xl:w-1/3 xl:sticky xl:top-32 h-fit mb-8 xl:mb-0">
            <h2 class="text-3xl font-bold mb-6">Project Context</h2>
            
            <div class="flex flex-col gap-4 border-l-2 border-zinc-800 pl-6">
                <div>
                    <span class="text-zinc-500 font-mono text-xs uppercase tracking-widest block mb-1">Timeframe</span>
                    <span class="text-white text-lg font-medium">{project.data.pubDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</span>
                </div>
                <div>
                    <span class="text-zinc-500 font-mono text-xs uppercase tracking-widest block mb-1">Primary Discipline</span>
                    <span class="text-white text-lg font-medium">{primaryCategory}</span>
                </div>
            </div>
        </div>
        
        <div class="xl:w-2/3 prose prose-invert prose-lg max-w-none prose-headings:font-bold prose-a:text-blue-400 hover:prose-a:text-blue-300 prose-img:rounded-3xl prose-img:w-full prose-img:h-auto prose-img:shadow-2xl">
            <Content />
        </div>

    </div>

    {isProposal && (
    <>
        <!-- Hardcoded Section: The Build Gallery -->
        <div class="w-full relative h-[60vh] flex items-center justify-center overflow-hidden">
            <video src="/proposal/IMG_1579.MP4" autoplay loop muted playsinline class="absolute inset-0 w-full h-full object-cover z-0 opacity-40"></video>
            <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-transparent to-zinc-950 mix-blend-overlay"></div>
            <div class="relative z-20 text-center px-4 max-w-4xl mx-auto">
                <h2 class="text-4xl md:text-6xl font-bold tracking-tighter mb-6 text-white drop-shadow-2xl">Fabrication & Assembly</h2>
                <p class="text-xl text-zinc-300 leading-relaxed drop-shadow-lg font-medium">The letters were constructed out of wood and cardboard to maintain a delicate balance between weight and structural integrity.</p>
            </div>
        </div>

        <!-- Section 3: The Result (Sticky Left, New Gallery Right) -->
        <div class="w-full px-4 md:px-16 py-24 flex flex-col xl:flex-row gap-16 border-t border-zinc-800">
            <div class="xl:w-1/3 xl:sticky xl:top-32 h-fit mb-12 xl:mb-0">
                <h2 class="text-3xl font-bold mb-6">The Deployment</h2>
                <p class="text-xl text-zinc-400 leading-relaxed mb-6">We hiked it up the trail out of sight, bolted it together, and when the sun went down, the visual impact was staggering.</p>
            </div>
            
            <div class="xl:w-2/3 flex flex-col gap-12">
                <img src="/proposal/FullMarryMe.jpg" class="w-full h-auto rounded-3xl border border-zinc-800 shadow-2xl" />
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <img src="/proposal/TestingM.jpg" class="w-full h-full object-cover rounded-3xl border border-zinc-800 shadow-xl" />
                    <img src="/proposal/LayingOnTestM.jpg" class="w-full h-full object-cover rounded-3xl border border-zinc-800 shadow-xl" />
                </div>
                
                <img src="/proposal/CardboardPile.jpg" class="w-full h-auto rounded-3xl border border-zinc-800 shadow-2xl" />
            </div>
        </div>
    </>
    )}

  </div>
</Layout>
