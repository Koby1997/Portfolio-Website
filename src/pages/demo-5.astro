---
import '../styles/global.css';
---
<!doctype html>
<html lang="en" class="dark scroll-smooth">
<head><meta charset="UTF-8" /><title>Demo 5 - Explicit Story Action</title></head>
<body class="bg-zinc-950 text-zinc-50 flex items-center justify-center h-screen overflow-hidden m-0 p-0 relative">
  
  <div class="relative z-10 flex flex-col items-start max-w-4xl px-8 w-full">
    <div class="w-16 h-1 bg-blue-500 mb-8"></div>
    <h1 class="text-6xl md:text-8xl font-bold text-white mb-6 tracking-tight">
      Hi, I'm K<span class="text-white relative group inline-block mx-1">
        o
        <!-- Subtle pulsing dot -->
        <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 bg-blue-500 rounded-full animate-pulse shadow-[0_0_10px_#3b82f6]"></span>
      </span>by.
    </h1>
    <p class="text-2xl text-zinc-400 mb-12 font-light max-w-2xl">
      I engineer robust software and craft dynamic hardware interfaces. 
    </p>
    
    <!-- Explicit Call To Action Panel -->
    <div class="p-6 border border-zinc-800 rounded-xl bg-zinc-900/40 hover:bg-zinc-900/80 hover:border-blue-500/50 transition-all duration-300 cursor-pointer group relative max-w-lg overflow-hidden">
       <!-- Gradient hover wash -->
       <div class="absolute inset-0 bg-gradient-to-r from-blue-500/0 via-blue-500/5 to-blue-500/0 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000 ease-out"></div>
       
       <h3 class="text-xl text-white font-medium mb-3 flex items-center gap-3">
         <div class="w-2 h-2 bg-blue-500 rounded-full group-hover:scale-150 transition-transform"></div>
         Explore My Mind
       </h3>
       <p class="text-zinc-400 text-sm leading-relaxed mb-6">
         Before you see my projects, you should see how I think. Click here to zoom into my interactive 3D Neural Map.
       </p>
       
       <div class="text-blue-400 text-xs font-mono tracking-widest flex items-center gap-2 group-hover:gap-4 transition-all">
         ENTER THE BRAIN <span class="text-lg">→</span>
       </div>
    </div>
  </div>

  <div class="absolute top-8 right-8 z-50">
    <a href="/" class="text-zinc-500 hover:text-white px-4 py-2 border border-zinc-800 rounded-lg bg-zinc-900 hover:bg-zinc-800 transition">Return to Home</a>
  </div>
</body>
</html>
