---
import '../styles/global.css';
---
<!doctype html>
<html lang="en" class="dark scroll-smooth">
<head>
	<meta charset="UTF-8" />
	<title>Demo 2 - Elegant Glass</title>
</head>
<body class="bg-zinc-950 text-zinc-50 font-sans antialiased overflow-x-hidden m-0 p-0">
  <div class="absolute top-8 right-8 z-50">
    <a href="/" class="text-zinc-500 hover:text-white px-4 py-2 border border-zinc-800 rounded-lg bg-zinc-900 hover:bg-zinc-800 transition">Return to Home</a>
  </div>

  <section class="relative w-full h-screen bg-zinc-950 flex flex-col items-center justify-center pb-20 group">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-blue-600/10 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="relative z-10 flex flex-col items-center text-center max-w-3xl px-6">
      <p class="text-xl text-zinc-400 tracking-widest uppercase mb-8 font-light">Hello there</p>
      <h1 class="text-7xl md:text-[8rem] font-medium tracking-tight text-transparent bg-clip-text bg-gradient-to-br from-white to-zinc-500 cursor-pointer">
        I am K<span class="relative inline-block text-white">o<span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-1.5 h-1.5 bg-blue-400 rounded-full opacity-70"></span></span>by
      </h1>
      <p class="mt-8 text-zinc-500 text-xl sm:text-2xl font-light leading-relaxed">
        I build high-performance web applications and dynamic hardware systems. Welcome to my digital workspace.
      </p>
    </div>
  </section>
</body>
</html>
