---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Layout 2: Split Screen Gallery">
  <div class="w-screen relative left-[calc(-50vw+50%)] bg-zinc-950 text-white md:h-screen overflow-hidden flex flex-col md:flex-row">
    
    <!-- Left Panel (Sticky Info) -->
    <div class="w-full md:w-[40%] h-auto md:h-full bg-zinc-900 border-r border-zinc-800 p-8 md:p-16 flex flex-col justify-center relative overflow-y-auto">
        
        <div class="flex flex-wrap gap-2 mb-8 mt-12 md:mt-0">
            <span class="px-3 py-1 bg-purple-500/20 text-purple-400 text-[10px] font-bold tracking-widest uppercase rounded border border-purple-500/30">Milestone</span>
            <span class="px-3 py-1 bg-cyan-500/20 text-cyan-400 text-[10px] font-bold tracking-widest uppercase rounded border border-cyan-500/30">Fabrication</span>
        </div>
        
        <h1 class="text-5xl lg:text-7xl font-bold tracking-tighter mb-6 relative z-10"><span class="text-purple-500">The</span><br/>Proposal</h1>
        <p class="text-xl text-zinc-400 leading-relaxed mb-8">A complex logistical surprise featuring giant 12-foot illuminated letters constructed by hand and deployed to a mountain peak.</p>
        
        <div class="p-6 bg-zinc-950 rounded-2xl border border-zinc-800 font-mono text-purple-400 text-sm shadow-inner mt-8">
            <span class="text-zinc-600 block mb-2">// LOGISTICS_CRITICAL</span>
            <span class="opacity-80">Required modular construction so the props could be broken down, driven, hiked, and reassembled out of sight.</span>
        </div>
    </div>

    <!-- Right Panel (Infinite Scrolling Photos) -->
    <div class="w-full md:w-[60%] h-auto md:h-full overflow-y-auto p-4 md:p-8 bg-zinc-950 custom-scrollbar relative">
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-4 pb-24">
            
            <div class="h-[400px] w-full bg-zinc-900 rounded-2xl border border-zinc-800 flex items-center justify-center text-zinc-600 relative overflow-hidden group">
                <img src="/proposal/335C4B18-9400-456A-ADC1-DE17AE1CCFB1.jpg" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
            </div>

            <div class="h-[300px] xl:h-[400px] w-full bg-zinc-900 rounded-2xl border border-zinc-800 flex items-center justify-center text-zinc-600 overflow-hidden">
                <video src="/proposal/IMG_7455.MP4" autoplay loop muted playsinline class="w-full h-full object-cover"></video>
            </div>

            <!-- Full Width Breakout inside Gallery -->
            <div class="h-[600px] xl:col-span-2 w-full bg-zinc-900 rounded-2xl border border-zinc-800 flex items-center justify-center text-zinc-600 overflow-hidden shadow-2xl relative">
                <video src="/proposal/IMG_1579.MP4" autoplay loop muted playsinline class="w-full h-full object-cover z-0"></video>
                <div class="absolute bottom-8 left-8 bg-zinc-900/80 backdrop-blur px-6 py-3 rounded-xl border border-zinc-800 z-10 text-white font-bold tracking-widest uppercase">Visual Proof</div>
            </div>

            <div class="h-[500px] w-full bg-zinc-900 rounded-2xl border border-zinc-800 flex items-center justify-center text-zinc-600 overflow-hidden">
                <img src="/proposal/IMG_8779.JPG" class="w-full h-full object-cover" />
            </div>
            
            <div class="h-[500px] w-full bg-zinc-900 rounded-2xl border border-zinc-800 flex items-center justify-center text-zinc-600 overflow-hidden">
                <img src="/proposal/20220514_142201.jpg" class="w-full h-full object-cover" />
            </div>

        </div>
    </div>

  </div>

  <style>
    .custom-scrollbar::-webkit-scrollbar { width: 8px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #27272a; border-radius: 4px; }
  </style>
</Layout>
